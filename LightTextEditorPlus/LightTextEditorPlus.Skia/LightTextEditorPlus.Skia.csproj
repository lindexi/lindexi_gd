<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>LightTextEditorPlus</RootNamespace>
    <UseUIFramework>Skia</UseUIFramework>
    <IsTrimmable>true</IsTrimmable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="2.88.7" />
    <PackageReference Include="SkiaSharp.HarfBuzz" Version="2.88.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LightTextEditorPlus.Core\LightTextEditorPlus.Core.csproj" />
    <ProjectReference Include="..\Analyzers\TextEditorInternalAnalyzer\TextEditorInternalAnalyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="LightTextEditorPlus.Avalonia.Tests" />
    <InternalsVisibleTo Include="LightTextEditorPlus.Skia.UnitTests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources\ExceptionMessages.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ExceptionMessages.Designer.cs</LastGenOutput>
      <CustomToolNamespace>LightTextEditorPlus.Resources.Skia</CustomToolNamespace>
      <LogicalName>LightTextEditorPlus.Resources.Skia.ExceptionMessages.resources</LogicalName>
      <WithCulture>false</WithCulture>
    </EmbeddedResource>
    <EmbeddedResource Update="Resources\ExceptionMessages.en-US.resx">
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
      <LogicalName>LightTextEditorPlus.Resources.Skia.ExceptionMessages.resources</LogicalName>
    </EmbeddedResource>
    <Compile Update="Resources\ExceptionMessages.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
