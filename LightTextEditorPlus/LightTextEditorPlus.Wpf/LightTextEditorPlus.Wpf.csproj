<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <RootNamespace>LightTextEditorPlus</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <UseUIFramework>Wpf</UseUIFramework>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\LightTextEditorPlus.Core\LightTextEditorPlus.Core.csproj" />
    <ProjectReference Include="..\Analyzers\TextEditorInternalAnalyzer\TextEditorInternalAnalyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Cursors\VerticalText.cur" />
    <EmbeddedResource Include="Resources\Cursors\VerticalText.cur" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources\ExceptionMessages.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ExceptionMessages.Designer.cs</LastGenOutput>
      <CustomToolNamespace>LightTextEditorPlus.Resources.Wpf</CustomToolNamespace>
      <LogicalName>LightTextEditorPlus.Resources.Wpf.ExceptionMessages.resources</LogicalName>
      <WithCulture>false</WithCulture>
    </EmbeddedResource>
    <EmbeddedResource Update="Resources\ExceptionMessages.en-US.resx">
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
      <LogicalName>LightTextEditorPlus.Resources.Wpf.ExceptionMessages.resources</LogicalName>
    </EmbeddedResource>
    <Compile Update="Resources\ExceptionMessages.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
