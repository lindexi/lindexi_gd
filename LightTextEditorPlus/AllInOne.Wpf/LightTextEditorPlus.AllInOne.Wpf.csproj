<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);USE_AllInOne</DefineConstants>
    <UseUIFramework>Wpf</UseUIFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <AssemblyName>LightTextEditorPlus.Wpf</AssemblyName>
    <!-- 为什么命名上会带一个 AllInOne 标识？ 因为还有不带 AllInOne 的版本，分开多个包的版本 -->
    <PackageId>LightTextEditorPlus.AllInOne.Wpf</PackageId>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\LightTextEditorPlus.Core\**\*.cs" LinkBase="Core" Exclude="..\LightTextEditorPlus.Core\obj\**\*;..\LightTextEditorPlus.Core\bin\**\*" />
    <Compile Include="..\LightTextEditorPlus.Wpf\**\*.cs" LinkBase="Wpf" Exclude="..\LightTextEditorPlus.Wpf\obj\**\*;..\LightTextEditorPlus.Wpf\bin\**\*" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\LightTextEditorPlus.Core\Resources\ExceptionMessages.resx">
      <Link>Core\Resources\ExceptionMessages.resx</Link>
      <WithCulture>false</WithCulture>
      <LogicalName>LightTextEditorPlus.Core.Resources.ExceptionMessages.resources</LogicalName>
      <CustomToolNamespace>LightTextEditorPlus.Core.Resources</CustomToolNamespace>
    </EmbeddedResource>
    <EmbeddedResource Include="..\LightTextEditorPlus.Core\Resources\ExceptionMessages.en-US.resx">
      <Link>Core\Resources\ExceptionMessages.en-US.resx</Link>
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
      <LogicalName>LightTextEditorPlus.Core.Resources.ExceptionMessages.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\LightTextEditorPlus.Wpf\Resources\ExceptionMessages.resx">
      <Link>Wpf\Resources\ExceptionMessages.resx</Link>
      <WithCulture>false</WithCulture>
      <CustomToolNamespace>LightTextEditorPlus.Resources.Wpf</CustomToolNamespace>
      <LogicalName>LightTextEditorPlus.Resources.Wpf.ExceptionMessages.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\LightTextEditorPlus.Wpf\Resources\ExceptionMessages.en-US.resx">
      <Link>Wpf\Resources\ExceptionMessages.en-US.resx</Link>
      <DependentUpon>ExceptionMessages.resx</DependentUpon>
      <LogicalName>LightTextEditorPlus.Resources.Wpf.ExceptionMessages.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Analyzers\TextEditorInternalAnalyzer\TextEditorInternalAnalyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
