<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <RootNamespace>LightTextEditorPlus</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="1.0.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.0.0" />
    <PackageReference Include="ColorCode.Core" Version="2.0.15" />

    <ProjectReference Include="..\LightTextEditorPlus.Wpf\LightTextEditorPlus.Wpf.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="**\*.ava.cs" />
  </ItemGroup>
</Project>
