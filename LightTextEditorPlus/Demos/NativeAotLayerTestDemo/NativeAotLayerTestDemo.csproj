<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Platforms>x86</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <SkiaAotPublishOutputPath>..\..\LightTextEditorPlus.Skia.AotLayer\bin\Release\net9.0\win-x86\publish\*.dll</SkiaAotPublishOutputPath>
    <SkiaAotPublishOutputPath Condition="'$(UseArtifactsOutput)' == 'true'">$(ArtifactsPath)\publish\LightTextEditorPlus.Skia.AotLayer\release_win-x86\*.dll</SkiaAotPublishOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(SkiaAotPublishOutputPath)" LinkBase="" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\LightTextEditorPlus.Skia.AotLayer\NativeTextEditors\**\*.cs" LinkBase="NativeTextEditors" />
  </ItemGroup>

</Project>
