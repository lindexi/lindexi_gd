<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);USE_Avalonia;</DefineConstants>
    <ArtifactsConfiguration>$([System.String]::Copy('$(Configuration)').ToLowerInvariant())</ArtifactsConfiguration>
    <AvaloniaResourceAssemblyPath>..\..\LightTextEditorPlus.Avalonia\bin\$(Configuration)\net8.0\en-US\*.resources.dll</AvaloniaResourceAssemblyPath>
    <AvaloniaResourceAssemblyPath Condition="'$(UseArtifactsOutput)' == 'true'">$(ArtifactsPath)\bin\LightTextEditorPlus.Avalonia\$(ArtifactsConfiguration)_net8.0\en-US\*.resources.dll</AvaloniaResourceAssemblyPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\LightTextEditorPlus.Tests\Framework_\TestFramework.Shared.cs" Link="Framework_\TestFramework.Shared.cs" />
    <Compile Include="..\LightTextEditorPlus.Tests\IntegrationTests\VisionCompareResultException.cs" Link="IntegrationTests\VisionCompareResultException.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" Version="3.11.0" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Demos\AvaloniaDemo\LightTextEditorPlus.AvaloniaDemo.csproj" />
    <ProjectReference Include="..\TextVisionComparer\TextVisionComparer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\TestImage\**\*" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(AvaloniaResourceAssemblyPath)"
          LinkBase="en-US"
          CopyToOutputDirectory="PreserveNewest"
          Visible="false" />
  </ItemGroup>

</Project>
