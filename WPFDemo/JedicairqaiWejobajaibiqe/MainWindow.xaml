<Window x:Class="JedicairqaiWejobajaibiqe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JedicairqaiWejobajaibiqe"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl>
        <!-- Tab 1: ItemsControl -->
        <TabItem Header="ItemsControl">
            <Grid RowDefinitions="*,Auto">
                <ScrollViewer x:Name="ItemsControlScrollViewer">
                    <ItemsControl x:Name="ItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:TextItem}">
                                <TextBlock Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           Margin="4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
                    <Button Margin="0,0,10,0" Content="添加项" Click="ItemsControl_AddItem_Click" />
                    <Button Margin="0,0,10,0" Content="添加内容" Click="ItemsControl_AddContent_Click" />
                    <Button Content="滚动到底部" Click="ItemsControl_ScrollToEnd_Click" />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Tab 2: ListView -->
        <TabItem Header="ListView">
            <Grid RowDefinitions="*,Auto">
                <ListView x:Name="ListView"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="False">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:TextItem}">
                            <TextBlock Text="{Binding Content}"
                                       TextWrapping="Wrap"
                                       Margin="4" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
                    <Button Margin="0,0,10,0" Content="添加项" Click="ListView_AddItem_Click" />
                    <Button Margin="0,0,10,0" Content="添加内容" Click="ListView_AddContent_Click" />
                    <Button Content="滚动到底部" Click="ListView_ScrollToEnd_Click" />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Tab 3: ListBox -->
        <TabItem Header="ListBox">
            <Grid RowDefinitions="*,Auto">
                <ListBox x:Name="ListBox"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:TextItem}">
                            <TextBlock Text="{Binding Content}"
                                       TextWrapping="Wrap"
                                       Margin="4" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
                    <Button Margin="0,0,10,0" Content="添加项" Click="ListBox_AddItem_Click" />
                    <Button Margin="0,0,10,0" Content="添加内容" Click="ListBox_AddContent_Click" />
                    <Button Content="滚动到底部" Click="ListBox_ScrollToEnd_Click" />
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
