<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.MainContentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:converters="clr-namespace:CoursewarePptxGeneratorWpfDemo.Converters"
             Background="{StaticResource LightBackgroundBrush}">
    <Grid Background="{StaticResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开课件文件夹"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,12,0"
                            Click="OpenCoursewareFolderButton_OnClick" />
                    <TextBlock Text="{Binding SelectedSlide.Status, TargetNullValue=No Courseware}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Ellipse Width="10" Height="10" Margin="8,0,0,0" Fill="{StaticResource SuccessGreenBrush}" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="课件美化工作台"
                               FontWeight="Bold"
                               FontSize="20"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SelectedSlide.Summary, TargetNullValue=尚未加载课件内容。}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding CoursewareFolderDisplayText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="680"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource PreviewBackgroundBrush}" Padding="24,16">
            <Border Style="{StaticResource WorkspaceCardStyle}" Padding="18">
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="1280"
                          Height="720">
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="#f8fafc">
                            <Image Source="{Binding SlideChatManager.PreviewImage, Converter={x:Static converters:PreviewImageToImageSourceConverter.Instance}}"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasPreviewImage, Converter={x:Static converters:InverseBooleanToVisibilityConverter.Instance}}"
                                    IsHitTestVisible="False">
                            <TextBlock Text="未加载课件页面"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="选择课件文件夹并生成 SlideML 后，这里显示 16:9 页面预览。"
                                       FontSize="18"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextAlignment="Center"
                                       Margin="0,16,0,0" />
                        </StackPanel>
                    </Grid>
                </Viewbox>
            </Border>
        </Border>

        <Border Grid.Row="2" Margin="24,0,24,24" Style="{StaticResource WorkspaceCardStyle}">
            <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="重新加载"
                                Command="{Binding RerenderCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,6" />
                        <TextBlock Text="Current SlideML Content"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="0,0,0,12" Margin="0,0,1,0">
                        <TextBox Text="{Binding EditableSlideXml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CodeTextBoxStyle}" />
                    </Border>

                    <Border Grid.Column="1" CornerRadius="0,0,12,0" ClipToBounds="True">
                        <TabControl Style="{StaticResource ModernTabControl}">
                            <TabItem Header="Rendering Log" Style="{StaticResource ModernTabItem}">
                                <TextBox Text="{Binding RenderingLog, Mode=OneWay, TargetNullValue=尚未执行渲染。}"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         Padding="16"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </TabItem>
                            <TabItem Header="Callback XML" Style="{StaticResource ModernTabItem}">
                                <TextBox Text="{Binding CallbackXml, Mode=OneWay, TargetNullValue=''}"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         Padding="16"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
