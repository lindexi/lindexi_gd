<UserControl x:Class="CheawuchewalYicheredurlakearja.Views.CopilotPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource LightBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 标题栏 -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,12">
                <TextBlock Text="Copilot" 
                          FontWeight="Bold" 
                          FontSize="16"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="..." Width="32" Height="32" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="0" Margin="0,0,8,0"/>
                    <Button Content="×" Width="32" Height="32" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="0" FontSize="18"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. 聊天气泡图标区 -->
        <Grid Grid.Row="1" Width="80" Height="80" Margin="0,24,0,16" HorizontalAlignment="Center">
            <!-- 灰色轮廓气泡 -->
            <Border Width="60" Height="60" 
                   Background="#E2E8F0" 
                   BorderBrush="{StaticResource BorderBrush}" 
                   BorderThickness="2"
                   CornerRadius="30"
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top"
                   Margin="0,0,0,0"/>
            <!-- 蓝色填充气泡 -->
            <Border Width="60" Height="60" 
                   Background="{StaticResource PrimaryBlueBrush}" 
                   CornerRadius="30"
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,0"/>
        </Grid>

        <!-- 3. 聊天消息区 -->
        <ScrollViewer Grid.Row="2" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Disabled"
                     Margin="16,0">
            <StackPanel>
                <TextBlock Text="Copilot: Hello, I am Copilot. Please enter your request."
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="14"
                          Margin="0,0,0,16"
                          TextWrapping="Wrap"/>
                <TextBlock Text="Page 1 contains a title slide with the presentation name 'SlideML Lab' and subtitle 'Creating Professional Presentations with AI-Powered Markup'. The slide features a clean, modern design with a gradient background transitioning from blue to purple, centered text layout, and subtle geometric patterns in the corners."
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="13"
                          TextWrapping="Wrap"
                          LineHeight="20"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 4. 输入区域 -->
        <Border Grid.Row="3" 
               Background="White" 
               BorderBrush="{StaticResource BorderBrush}" 
               BorderThickness="0,1,0,1"
               Padding="16,12">
            <StackPanel>
                <!-- ComboBox 选择区 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox Width="120" 
                             SelectedIndex="0"
                             Margin="0,0,8,0">
                        <ComboBoxItem Content="GPT-4"/>
                    </ComboBox>
                    <ComboBox Width="140" 
                             SelectedIndex="0">
                        <ComboBoxItem Content="SlideML-LLM"/>
                    </ComboBox>
                </StackPanel>

                <!-- 多行输入框 -->
                <TextBox Height="80"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        Margin="0,0,0,12"
                        FontSize="13"
                        Padding="8">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 占位符提示（Grid 叠加层） -->
                <Grid Height="0" Margin="0,-80,0,0">
                    <TextBlock Text="请求提你的想象力，制作一个精美的页面介介绍，我是 Copilot，请开始输入你的问题。"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              Margin="8,8,0,0"
                              IsHitTestVisible="False"
                              Opacity="0.6"/>
                </Grid>

                <!-- 按钮区 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Image" 
                           Width="80" 
                           Height="36"
                           Style="{StaticResource SecondaryButtonStyle}"
                           Margin="0,0,8,0"/>
                    <Button Content="Send" 
                           Width="80" 
                           Height="36"
                           Style="{StaticResource DarkButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 5. 底部按钮栏 -->
        <Border Grid.Row="4" 
               Background="White" 
               BorderBrush="{StaticResource BorderBrush}" 
               BorderThickness="0,1,0,0"
               Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Finalize" 
                       Width="100" 
                       Height="36"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Margin="0,0,8,0"/>
                <Button Content="Preview All" 
                       Width="120" 
                       Height="36"
                       Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
