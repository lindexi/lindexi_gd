<Window x:Class="LeefayjehekijawlalWhichayfawcelhega.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:LeefayjehekijawlalWhichayfawcelhega.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel, IsDesignTimeCreatable=False}"
        Title="AI 多页课件生成工作台"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="720">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Text="AI 多页课件生成工作台" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#666"
                       Text="先配置服务参数，再把完整大纲交给 Agent 决定分页，随后逐页确认生成图片。" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="16"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="PPT 大纲输入" />
                    <TextBlock Margin="0,6,0,10"
                               Foreground="#666"
                               Text="此处输入完整大纲，由 Agent 自主决定拆成多少页，并通过工具返回逐页图片提示词。" />
                    <TextBox MinHeight="180"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Text="{Binding OutlineText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="模型服务配置" />
                    <TextBlock Margin="0,8,0,0" Text="服务地址" />
                    <TextBox Margin="0,4,0,8"
                             Text="{Binding ServiceEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="API Key" />
                    <TextBox Margin="0,4,0,8"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="提示词模型" />
                    <TextBox Margin="0,4,0,8"
                             Text="{Binding PromptModelId, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="图片模型" />
                    <TextBox Margin="0,4,0,8"
                             Text="{Binding ImageModelId, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="导出目录" />
                    <TextBox Margin="0,8,0,12"
                             Text="{Binding ExportRootDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Width="200"
                            Height="40"
                            HorizontalAlignment="Left"
                            Command="{Binding GeneratePromptsCommand}"
                            Content="根据完整大纲生成逐页提示词" />

                    <TextBlock Margin="0,16,0,0"
                               FontWeight="SemiBold"
                               Text="当前状态" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="页面列表" />
                    <Button Width="120"
                            Height="36"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Command="{Binding AddSlideCommand}"
                            Content="新增页面" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Slides}"
                              d:ItemsSource="{d:SampleData ItemCount=2}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,16"
                                    Padding="16"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    d:DataContext="{d:DesignInstance Type=viewModels:SlidePageViewModel, IsDesignTimeCreatable=False}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.4*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="3.2*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding PageNumber, StringFormat=第 {0} 页}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="图片提示词" />
                                        <TextBox Margin="0,6,0,0"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 MinHeight="220"
                                                 Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="#666"
                                                   Text="{Binding StageText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#C62828"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ErrorMessage}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontWeight="SemiBold" Text="候选图片（默认选中第一张）" />
                                        <TextBlock Margin="0,6,0,10"
                                                   Foreground="#666"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding EmptyImageMessage}" />
                                        <ListBox MinHeight="260"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 ItemsSource="{Binding ImageCandidates}"
                                                 SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                                 d:ItemsSource="{d:SampleData ItemCount=4}">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,12,12"
                                                            Padding="8"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            d:DataContext="{d:DesignInstance Type=viewModels:ImageCandidateViewModel, IsDesignTimeCreatable=False}">
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Text="{Binding DisplayName}" />
                                                            <Image Margin="0,8,0,0"
                                                                   Height="170"
                                                                   Stretch="UniformToFill"
                                                                   Source="{Binding PreviewImage}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4"
                                                VerticalAlignment="Top">
                                        <Button Height="44"
                                                Margin="0,0,0,8"
                                                Command="{Binding GenerateImagesCommand}"
                                                Content="{Binding GenerateButtonText}" />
                                        <Button Height="44"
                                                Margin="0,0,0,8"
                                                Command="{Binding DeleteSlideCommand}"
                                                Content="删除页面" />
                                        <TextBlock Foreground="#666"
                                                   TextWrapping="Wrap"
                                                   Text="用户点击当前按钮后，才会调用图片模型生成该页候选图。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#666"
                       Text="导出时会将已选图片输出到预设目录下的时间命名子文件夹。" />
            <Button Width="180"
                    Height="44"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Command="{Binding ExportCommand}"
                    Content="导出已选图片" />
        </DockPanel>
    </Grid>
</Window>
