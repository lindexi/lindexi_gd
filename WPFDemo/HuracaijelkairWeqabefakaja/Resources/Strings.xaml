<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <system:String x:Key="ApplicationTitle">轨道图标生成器</system:String>
    <system:String x:Key="HeroTitle">绘制一次，导出完整图标集</system:String>
    <system:String x:Key="HeroSubtitle">使用同一份 WPF 矢量图生成透明 PNG 与多尺寸 ICO，确保预览和最终文件保持一致。</system:String>
    <system:String x:Key="TechnologyBadgeText">WPF · VECTOR · PNG · ICO</system:String>
    <system:String x:Key="PreviewTitle">矢量预览</system:String>
    <system:String x:Key="PreviewCaption">透明背景 · 512 × 512 设计坐标</system:String>
    <system:String x:Key="OutputTitle">输出位置</system:String>
    <system:String x:Key="FormatsTitle">自动生成</system:String>
    <system:String x:Key="PngSizesText">PNG · 512 / 64 / 32 / 16</system:String>
    <system:String x:Key="IcoSizesText">ICO · 16 / 32 / 64 / 256</system:String>
    <system:String x:Key="TransparentPngTitle">透明 PNG</system:String>
    <system:String x:Key="TransparentPngDescription">ICO 使用 32 位透明 PNG 帧，可用于现代 Windows 应用图标。</system:String>
    <system:String x:Key="SaveButtonText">生成并保存图标</system:String>
    <system:String x:Key="ReadyStatusText">准备就绪</system:String>
    <system:String x:Key="SavingStatusText">正在生成图标文件…</system:String>
    <system:String x:Key="SavedStatusText">图标已保存到输出文件夹。</system:String>
    <system:String x:Key="SaveFailedStatusPrefix">保存失败：</system:String>
    <system:String x:Key="OpenFolderHintText">文件将固定保存到程序输出目录下的 GeneratedIcons 文件夹。</system:String>
</ResourceDictionary>
