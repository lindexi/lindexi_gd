<Window x:Class="CakawuhealehaneJairijelanefer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CakawuhealehaneJairijelanefer"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="920"
        Height="620"
        MinWidth="760"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="36">
        <Border MaxWidth="840"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource PreviewCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource IconSurfaceStyle}">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="300" Height="300">
                            <Ellipse Width="210"
                                     Height="32"
                                     Margin="0,224,0,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Fill="#244F7FAE"
                                     IsHitTestVisible="False" />
                            <Image Margin="20"
                                   Source="{Binding IconPreview}"
                                   Style="{StaticResource PreviewImageStyle}" />
                        </Grid>
                    </Viewbox>
                </Border>

                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Heading}"
                               Style="{StaticResource HeadingTextStyle}" />

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="{Binding Description}"
                               Style="{StaticResource DescriptionTextStyle}" />

                    <StackPanel Grid.Row="2" Margin="0,28,0,0">
                        <TextBlock Text="{Binding OutputDirectoryLabel}"
                                   Style="{StaticResource SectionLabelTextStyle}" />
                        <Border Margin="0,8,0,0" Style="{StaticResource InformationPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding OutputDirectory}"
                                           Style="{StaticResource PathTextStyle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding OutputFolderHint}"
                                           Style="{StaticResource DescriptionTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,20,0,0">
                        <TextBlock Text="{Binding FormatsLabel}"
                                   Style="{StaticResource SectionLabelTextStyle}" />
                        <TextBlock Margin="0,7,0,0"
                                   Text="{Binding FormatsValue}"
                                   Style="{StaticResource ValueTextStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,28,0,0">
                        <Button Command="{Binding ExportCommand}"
                                Content="{Binding ExportButtonText}"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding Status}"
                                   Style="{StaticResource StatusTextStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
