<UserControl x:Class="CheawuchewalYicheredurlakearja.Views.MainContentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ 1. 顶部标题栏 ═══════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,12">
            <DockPanel>
                <!-- 右侧状态指示 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ready"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                    <Ellipse Width="10" Height="10" Margin="8,0,0,0"
                             Fill="{StaticResource SuccessGreenBrush}"/>
                </StackPanel>

                <!-- 左侧标题 -->
                <TextBlock Text="SlideML Lab"
                           FontWeight="Bold" FontSize="20"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══════════ 2. 幻灯片预览区 ═══════════ -->
        <Border Grid.Row="1" Background="#f0f4ff" Padding="24,20">
            <Border Background="White" CornerRadius="12" Padding="24"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── 左上：页面概览 + 柱状图 ── -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                        <TextBlock Text="页面概览" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Canvas Width="200" Height="100" Background="#f8fafc" ClipToBounds="True">
                            <Rectangle Canvas.Left="10"  Canvas.Top="60" Width="24" Height="40" Fill="{StaticResource PrimaryBlueBrush}"/>
                            <Rectangle Canvas.Left="44"  Canvas.Top="40" Width="24" Height="60" Fill="#60A5FA"/>
                            <Rectangle Canvas.Left="78"  Canvas.Top="20" Width="24" Height="80" Fill="{StaticResource PrimaryBlueBrush}"/>
                            <Rectangle Canvas.Left="112" Canvas.Top="50" Width="24" Height="50" Fill="#60A5FA"/>
                            <Rectangle Canvas.Left="146" Canvas.Top="30" Width="24" Height="70" Fill="{StaticResource PrimaryBlueBrush}"/>
                        </Canvas>
                    </StackPanel>

                    <!-- ── 右上：两张图片占位符 ── -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="120" Height="80" CornerRadius="8" Margin="0,0,12,0" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#93C5FD" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="24" Foreground="#80FFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="120" Height="80" CornerRadius="8" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#A5B4FC" Offset="0"/>
                                    <GradientStop Color="#6366F1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="24" Foreground="#80FFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- ── 左下：选择带告 + 柱状图 ── -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,16">
                        <TextBlock Text="选择带告" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Canvas Width="200" Height="80" Background="#f8fafc" ClipToBounds="True">
                            <Rectangle Canvas.Left="10"  Canvas.Top="50" Width="20" Height="30" Fill="#60A5FA"/>
                            <Rectangle Canvas.Left="40"  Canvas.Top="30" Width="20" Height="50" Fill="{StaticResource PrimaryBlueBrush}"/>
                            <Rectangle Canvas.Left="70"  Canvas.Top="40" Width="20" Height="40" Fill="#60A5FA"/>
                            <Rectangle Canvas.Left="100" Canvas.Top="20" Width="20" Height="60" Fill="{StaticResource PrimaryBlueBrush}"/>
                            <Rectangle Canvas.Left="130" Canvas.Top="45" Width="20" Height="35" Fill="#60A5FA"/>
                            <Rectangle Canvas.Left="160" Canvas.Top="25" Width="20" Height="55" Fill="{StaticResource PrimaryBlueBrush}"/>
                        </Canvas>
                    </StackPanel>

                    <!-- ── 中下：多段概览 + 描述文字 ── -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,16">
                        <TextBlock Text="多段概览" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   LineHeight="18">
                            本段落展示了多段内容的概览信息，<LineBreak/>
                            包含关键数据指标与趋势分析结果，<LineBreak/>
                            用于快速了解幻灯片整体内容结构。
                        </TextBlock>
                    </StackPanel>

                    <!-- ── 右下：城市夜景图片占位符 ── -->
                    <Border Grid.Row="1" Grid.Column="2" CornerRadius="8" ClipToBounds="True"
                            MinHeight="120">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                                <GradientStop Color="#1E293B" Offset="0"/>
                                <GradientStop Color="#334155" Offset="0.5"/>
                                <GradientStop Color="#0F172A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Canvas ClipToBounds="True">
                                <Rectangle Canvas.Left="20"  Canvas.Top="40" Width="16" Height="30" Fill="#FBBF24" Opacity="0.7"/>
                                <Rectangle Canvas.Left="42"  Canvas.Top="30" Width="20" Height="40" Fill="#F59E0B" Opacity="0.6"/>
                                <Rectangle Canvas.Left="68"  Canvas.Top="20" Width="14" Height="50" Fill="#FBBF24" Opacity="0.8"/>
                                <Rectangle Canvas.Left="88"  Canvas.Top="35" Width="18" Height="35" Fill="#FCD34D" Opacity="0.5"/>
                                <Rectangle Canvas.Left="112" Canvas.Top="25" Width="22" Height="45" Fill="#F59E0B" Opacity="0.7"/>
                                <Rectangle Canvas.Left="140" Canvas.Top="45" Width="12" Height="25" Fill="#FBBF24" Opacity="0.6"/>
                            </Canvas>
                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="24" Foreground="#40FFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ═══════════ 3. Current SlideML Content 区域 ═══════════ -->
        <Border Grid.Row="2" Margin="24,0,24,24"
                Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel>

                <!-- 标题栏 -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <DockPanel>
                        <!-- 右侧操作按钮 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="&#x22EF;" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                       Cursor="Hand"/>
                            <TextBlock Text="✕" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Cursor="Hand"/>
                        </StackPanel>

                        <!-- 标题 -->
                        <TextBlock Text="Current SlideML Content"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- 内容区域 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：XML 代码编辑器 -->
                    <Border Grid.Column="0" Background="{StaticResource DarkBackgroundBrush}"
                            CornerRadius="0,0,0,12" Padding="16" Margin="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Consolas" FontSize="13"
                                       Foreground="#D4D4D4" LineHeight="20">
                                <Run Foreground="#569CD6">&lt;?</Run><Run Foreground="#9CDCFE">xml</Run>
                                <Run Foreground="#92C5F7"> version</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"1.0"</Run>
                                <Run Foreground="#92C5F7"> encoding</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"UTF-8"</Run><Run Foreground="#569CD6">?&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">&lt;</Run><Run Foreground="#4EC9B0">slideML</Run>
                                <Run Foreground="#92C5F7"> xmlns</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"urn:slideml:schema:v1"</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#808080">  &lt;!-- Slide definition --&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">  &lt;</Run><Run Foreground="#4EC9B0">slide</Run>
                                <Run Foreground="#92C5F7"> id</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"slide-001"</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">    &lt;</Run><Run Foreground="#4EC9B0">title</Run><Run Foreground="#569CD6">&gt;</Run><Run Foreground="#D4D4D4">页面概览</Run><Run Foreground="#569CD6">&lt;/</Run><Run Foreground="#4EC9B0">title</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">    &lt;</Run><Run Foreground="#4EC9B0">layout</Run>
                                <Run Foreground="#92C5F7"> type</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"two-column"</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">      &lt;</Run><Run Foreground="#4EC9B0">chart</Run>
                                <Run Foreground="#92C5F7"> chartType</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"bar"</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">        &lt;</Run><Run Foreground="#4EC9B0">data</Run>
                                <Run Foreground="#92C5F7"> values</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"40,60,80,50,70"</Run><Run Foreground="#569CD6"> /&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">      &lt;/</Run><Run Foreground="#4EC9B0">chart</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">    &lt;/</Run><Run Foreground="#4EC9B0">layout</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">  &lt;/</Run><Run Foreground="#4EC9B0">slide</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                <Run Foreground="#569CD6">&lt;/</Run><Run Foreground="#4EC9B0">slideML</Run><Run Foreground="#569CD6">&gt;</Run>
                            </TextBlock>
                        </ScrollViewer>
                    </Border>

                    <!-- 右侧：TabControl -->
                    <Border Grid.Column="1" Padding="0,0,0,0"
                            CornerRadius="0,0,12,0" ClipToBounds="True">
                        <TabControl Style="{StaticResource ModernTabControl}">
                            <TabItem Header="Rendering Log" Style="{StaticResource ModernTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               LineHeight="18">
                                        [INFO] Loading slide-001...<LineBreak/>
                                        [INFO] Parsing layout: two-column<LineBreak/>
                                        [INFO] Chart rendered: bar (5 data points)<LineBreak/>
                                        [INFO] Image placeholders resolved: 3<LineBreak/>
                                        [INFO] Slide rendering completed in 142ms<LineBreak/>
                                        [INFO] Ready for preview.
                                    </TextBlock>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Callback XML" Style="{StaticResource ModernTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               LineHeight="18">
                                        <Run Foreground="#569CD6">&lt;</Run><Run Foreground="#4EC9B0">callback</Run>
                                        <Run Foreground="#92C5F7"> event</Run><Run Foreground="#D4D4D4">=</Run><Run Foreground="#CE9178">"onRenderComplete"</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                        <Run Foreground="#569CD6">  &lt;</Run><Run Foreground="#4EC9B0">status</Run><Run Foreground="#569CD6">&gt;</Run><Run Foreground="{StaticResource TextPrimaryBrush}">success</Run><Run Foreground="#569CD6">&lt;/</Run><Run Foreground="#4EC9B0">status</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                        <Run Foreground="#569CD6">  &lt;</Run><Run Foreground="#4EC9B0">duration</Run><Run Foreground="#569CD6">&gt;</Run><Run Foreground="{StaticResource TextPrimaryBrush}">142</Run><Run Foreground="#569CD6">&lt;/</Run><Run Foreground="#4EC9B0">duration</Run><Run Foreground="#569CD6">&gt;</Run><LineBreak/>
                                        <Run Foreground="#569CD6">&lt;/</Run><Run Foreground="#4EC9B0">callback</Run><Run Foreground="#569CD6">&gt;</Run>
                                    </TextBlock>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
