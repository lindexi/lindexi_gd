<UserControl x:Class="VirtualFileExplorer.Views.FileExplorerUserControl"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="DefaultToolbarStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ToolBarContent, ElementName=RootControl}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomToolbarStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ToolBarContent, ElementName=RootControl}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TileContentStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasEntries}" Value="True" />
                        <Condition Binding="{Binding IsTileView}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailsContentStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasEntries}" Value="True" />
                        <Condition Binding="{Binding IsDetailsView}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DefaultEmptyStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasEntries}" Value="False" />
                        <Condition Binding="{Binding EmptyContent, ElementName=RootControl}" Value="{x:Null}" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomEmptyStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasEntries}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding EmptyContent, ElementName=RootControl}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="DefaultTileEntryTemplate">
            <Border Width="180"
                    Margin="6"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFDADADA"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF666666"
                               Text="{Binding DisplayType}" />
                    <TextBlock Foreground="#FF666666"
                               Text="{Binding DisplaySize}" />
                    <TextBlock Foreground="#FF666666"
                               Text="{Binding DisplayModifiedTime}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DefaultDetailsEntryTemplate">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" SharedSizeGroup="NameColumn" />
                    <ColumnDefinition Width="1.5*" SharedSizeGroup="TypeColumn" />
                    <ColumnDefinition Width="1.5*" SharedSizeGroup="SizeColumn" />
                    <ColumnDefinition Width="2*" SharedSizeGroup="TimeColumn" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding DisplayType}" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="{Binding DisplaySize}" />
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Text="{Binding DisplayModifiedTime}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="#FFF7F7F7" BorderBrush="#FFD0D0D0" BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Style="{StaticResource DefaultToolbarStyle}">
                <Button Margin="0,0,8,0" Command="{Binding NavigateUpCommand}" Content="返回上级" />
                <Button Margin="0,0,8,0" Command="{Binding RefreshCommand}" Content="刷新" />
                <Button Margin="0,0,8,0" Click="OnCreateFolderClick" Content="新建文件夹" IsEnabled="{Binding CanCreateFolder}" />
                <Button Margin="0,0,8,0" Click="OnRenameClick" Content="重命名" IsEnabled="{Binding CanRenameSelected}" />
                <Button Margin="0,0,8,0" Click="OnCopyClick" Content="复制" IsEnabled="{Binding CanCopySelected}" />
                <Button Margin="0,0,8,0" Click="OnMoveClick" Content="移动" IsEnabled="{Binding CanMoveSelected}" />
                <Button Margin="0,0,8,0" Click="OnDeleteClick" Content="删除" IsEnabled="{Binding CanDeleteSelected}" />
                <Separator Margin="8,0" Width="1" />
                <Button Margin="0,0,8,0" Command="{Binding SwitchToTileViewCommand}" Content="平铺" />
                <Button Command="{Binding SwitchToDetailsViewCommand}" Content="详细列表" />
            </StackPanel>

            <ContentPresenter Grid.Row="0"
                              Content="{Binding ToolBarContent, ElementName=RootControl}"
                              Style="{StaticResource CustomToolbarStyle}" />

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,12"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Padding="6,2"
                                        Click="OnBreadcrumbClick"
                                        Content="{Binding Name}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Margin="6,0"
                                           VerticalAlignment="Center"
                                           Text=">">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <ListBox Style="{StaticResource TileContentStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemTemplate="{Binding TileEntryTemplate, ElementName=RootControl}"
                         ItemsSource="{Binding Entries}"
                         MouseDoubleClick="OnEntryDoubleClick"
                         SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <Grid Style="{StaticResource DetailsContentStyle}" Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="8,6"
                            Background="#FFEFEFEF"
                            BorderBrush="#FFDADADA"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" SharedSizeGroup="NameColumn" />
                                <ColumnDefinition Width="1.5*" SharedSizeGroup="TypeColumn" />
                                <ColumnDefinition Width="1.5*" SharedSizeGroup="SizeColumn" />
                                <ColumnDefinition Width="2*" SharedSizeGroup="TimeColumn" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="名称" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="类型" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="大小" />
                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="修改时间" />
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             Margin="0,8,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ItemTemplate="{Binding DetailsEntryTemplate, ElementName=RootControl}"
                             ItemsSource="{Binding Entries}"
                             MouseDoubleClick="OnEntryDoubleClick"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}" />
                </Grid>

                <Border Style="{StaticResource DefaultEmptyStyle}"
                        Background="#20FFFFFF"
                        CornerRadius="8">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="当前目录为空" />
                            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" Foreground="#FF666666" Text="可以创建文件夹，或切换到其他目录。" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentPresenter Content="{Binding EmptyContent, ElementName=RootControl}"
                                  Style="{StaticResource CustomEmptyStyle}" />
            </Grid>

            <Border Grid.Row="3"
                    Margin="0,12,0,0"
                    Padding="8,6"
                    Background="#FFF0F0F0"
                    CornerRadius="4">
                <TextBlock Foreground="#FF555555" Text="{Binding StatusText}" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Border>
</UserControl>


