<Window x:Class="VirtualFileExplorer.Views.FolderPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:VirtualFileExplorer.Views"
        mc:Ignorable="d"
        Title="选择文件夹"
        Height="520"
        Width="880"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ExplorerSurfaceBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VirtualFileExplorer;component/Themes/LightTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource ExplorerToolbarCardStyle}">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding NavigateUpCommand}" Content="返回上级" Style="{StaticResource ExplorerLightButtonStyle}" />
                <Button Command="{Binding RefreshCommand}" Content="刷新" Style="{StaticResource ExplorerLightButtonStyle}" />
                <TextBox MinWidth="240"
                         Style="{StaticResource ExplorerLightTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox DisplayMemberPath="DisplayName"
                          MinWidth="120"
                          SelectedValue="{Binding EntryFilter}"
                          SelectedValuePath="Value"
                          ItemsSource="{Binding FilterOptions}"
                          Style="{StaticResource ExplorerLightComboBoxStyle}" />
            </StackPanel>
        </Border>

        <views:BreadcrumbBarControl Grid.Row="1" Margin="0,14,0,14" />

        <Border Grid.Row="2" Style="{StaticResource ExplorerToolbarCardStyle}">
            <views:FileExplorerContentControl x:Name="PickerContentControl" />
        </Border>

        <Border Grid.Row="3" Margin="0,14,0,0" Style="{StaticResource ExplorerToolbarCardStyle}">
            <DockPanel>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource ExplorerMutedTextBrush}"
                           Text="{Binding StatusText}" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnUseCurrentFolderClick" Content="选择当前目录" Style="{StaticResource ExplorerLightButtonStyle}" />
                    <Button Click="OnConfirmClick" Content="确定" Style="{StaticResource ExplorerLightButtonStyle}" />
                    <Button Click="OnCancelClick" Content="取消" Style="{StaticResource ExplorerLightButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
