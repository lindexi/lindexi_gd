<Window x:Class="VirtualFileExplorer.Views.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="输入"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MinWidth="420"
        Background="{DynamicResource ExplorerSurfaceBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VirtualFileExplorer;component/Themes/LightTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="18" Style="{StaticResource ExplorerToolbarCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Foreground="{StaticResource ExplorerTextBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Text="{Binding PromptMessage}" />

            <TextBox x:Name="InputTextBox"
                     Grid.Row="1"
                     Margin="0,16,0,0"
                     Style="{StaticResource ExplorerLightTextBoxStyle}"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Click="OnConfirmClick" Content="确定" Style="{StaticResource ExplorerLightButtonStyle}" />
                <Button Click="OnCancelClick" Content="取消" Style="{StaticResource ExplorerLightButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
