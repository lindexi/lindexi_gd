<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF3F6FA" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFF8FAFD" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFDBEAFE" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF172033" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF526079" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#FF7C899F" />
        <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFDCE3ED" />
        <SolidColorBrush x:Key="SystemBubbleBrush" Color="#FFE8EEF7" />
        <SolidColorBrush x:Key="DeveloperBubbleBrush" Color="#FFEDE9FE" />
        <SolidColorBrush x:Key="AssistantAvatarBrush" Color="#FF0F766E" />
        <SolidColorBrush x:Key="ReasoningSurfaceBrush" Color="#FFF2F7FA" />
        <SolidColorBrush x:Key="ReasoningAccentBrush" Color="#FF648092" />
        <SolidColorBrush x:Key="ToolSurfaceBrush" Color="#FFFFF8E8" />
        <SolidColorBrush x:Key="ToolBorderBrush" Color="#FFF2D28C" />
        <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#FFFFF8E6" />
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#FFF0C96A" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#FF835E09" />
    </Styles.Resources>

    <Style Selector="Window.LogViewer">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="MinWidth" Value="960" />
        <Setter Property="MinHeight" Value="640" />
    </Style>
    <Style Selector="Border.Sidebar">
        <Setter Property="Background" Value="{StaticResource SidebarBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>
    <Style Selector="Border.Header">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Border.WarningCard">
        <Setter Property="Background" Value="{StaticResource WarningSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style Selector="Button.Primary:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
    </Style>
    <Style Selector="Button.Primary:disabled">
        <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="TextBox.PathInput">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="ListBox.SessionList">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.SessionList > ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Padding" Value="10,9" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.SessionList > ListBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
    </Style>
    <Style Selector="ListBox.SessionList > ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
    </Style>

    <Style Selector="TextBlock.AppTitle">
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.RoleName">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.Secondary">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.Metadata">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.WarningText">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Border.Avatar">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="Border.AssistantAvatar">
        <Setter Property="Background" Value="{StaticResource AssistantAvatarBrush}" />
    </Style>
    <Style Selector="Border.UserAvatar">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
    </Style>
    <Style Selector="Border.MessageBubbleAssistant">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12,12,12,4" />
        <Setter Property="Padding" Value="13,10" />
    </Style>
    <Style Selector="Border.MessageBubbleUser">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="CornerRadius" Value="12,12,4,12" />
        <Setter Property="Padding" Value="13,10" />
    </Style>
    <Style Selector="Border.MessageBubbleSystem">
        <Setter Property="Background" Value="{StaticResource SystemBubbleBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="Border.MessageBubbleDeveloper">
        <Setter Property="Background" Value="{StaticResource DeveloperBubbleBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="SelectableTextBlock.MessageContent">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="21" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="SelectableTextBlock.UserMessageContent">
        <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="21" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="SelectableTextBlock.CenteredMessageContent">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="SelectableTextBlock.DetailContent">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="SelectableTextBlock.MonospaceContent">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Expander.DetailExpander">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.ReasoningPanel">
        <Setter Property="Background" Value="{StaticResource ReasoningSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReasoningAccentBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,5,0,2" />
    </Style>
    <Style Selector="Border.ToolPanel">
        <Setter Property="Background" Value="{StaticResource ToolSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ToolBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,5,0,2" />
    </Style>
    <Style Selector="Border.UsageChip">
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="7,4" />
    </Style>
    <Style Selector="ProgressBar.Thin">
        <Setter Property="Height" Value="3" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
</Styles>
