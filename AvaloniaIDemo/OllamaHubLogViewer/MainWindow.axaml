<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OllamaHubLogViewer.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="820"
        x:Class="OllamaHubLogViewer.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Classes="LogViewer"
        Width="1320"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Title="OllamaHub 日志查看器">
    <Grid ColumnDefinitions="310,*">
        <Border Grid.Column="0" Classes="Sidebar">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <StackPanel Grid.Row="0" Margin="18,18,18,14" Spacing="4">
                    <TextBlock Classes="AppTitle" Text="OllamaHub 日志" />
                    <TextBlock Classes="Secondary"
                               Text="OpenAI 请求与流式响应会话"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="14,0,14,12" Spacing="8">
                    <TextBlock Classes="Secondary" Text="日志根目录" />
                    <TextBox Classes="PathInput"
                             Text="{Binding LogRootPath, Mode=TwoWay}"
                             Watermark="选择包含日期子目录的文件夹" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="Secondary"
                                   VerticalAlignment="Center"
                                   Text="{Binding SessionCountText}" />
                        <Button Grid.Column="1"
                                Classes="Primary"
                                Command="{Binding RefreshCommand}"
                                Content="刷新日志" />
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="2">
                    <ListBox Classes="SessionList"
                             Margin="8,0,8,8"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LogSessionViewModel">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Text="{Binding DateText}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="8,0,0,0"
                                               Classes="Metadata"
                                               Text="{Binding FileSummary}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="2"
                                               Margin="0,3,0,0"
                                               Classes="Metadata"
                                               Text="{Binding DirectoryName}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Margin="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding !HasSessions}"
                                Spacing="6">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="暂无日志会话" />
                        <TextBlock Classes="Secondary"
                                   Text="确认目录中包含按日期命名的子文件夹"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="3"
                        Padding="14,10"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Spacing="5">
                        <ProgressBar Classes="Thin"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsBusy}" />
                        <TextBlock Classes="Secondary"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">
            <Border Grid.Row="0" Classes="Header" Padding="20,15">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="AppTitle"
                                   Text="{Binding SessionTitle}"
                                   TextTrimming="CharacterEllipsis" />
                        <SelectableTextBlock Classes="DetailContent"
                                             IsVisible="{Binding HasSessionMetadata}"
                                             Text="{Binding SessionMetadataText}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="18,0,0,0"
                            Classes="UsageChip"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasUsage}">
                        <StackPanel Spacing="2" MaxWidth="520">
                            <TextBlock Classes="Metadata" Text="响应使用量" />
                            <SelectableTextBlock Classes="DetailContent"
                                                 Text="{Binding UsageSummaryText}" />
                            <SelectableTextBlock Classes="DetailContent"
                                                 IsVisible="{Binding HasUsageDetails}"
                                                 Text="{Binding UsageDetailsText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="18,12,18,0"
                    Classes="WarningCard"
                    IsVisible="{Binding HasWarnings}">
                <SelectableTextBlock Classes="DetailContent"
                                     Foreground="{StaticResource WarningTextBrush}"
                                     Text="{Binding WarningText}" />
            </Border>

            <Grid Grid.Row="2">
                <StackPanel Margin="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding !HasSelectedSession}"
                            Spacing="9">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="选择一个日志会话" />
                    <TextBlock Classes="Secondary"
                               MaxWidth="420"
                               Text="左侧会话按时间倒序排列。选择后将解析 request.log 与 response.log，并按角色还原完整对话。"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="Metadata"
                               HorizontalAlignment="Center"
                               Text="消息文本可用鼠标选择，并按 Ctrl+C 复制局部内容。" />
                </StackPanel>

                <StackPanel Margin="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsLoading}"
                            Spacing="10">
                    <ProgressBar Width="220" IsIndeterminate="True" />
                    <TextBlock Classes="Secondary" Text="正在解析会话日志..." />
                </StackPanel>

                <StackPanel Margin="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowEmptyState}"
                            Spacing="7">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="没有可显示的消息" />
                    <TextBlock Classes="Secondary"
                               Text="请查看上方警告，确认日志文件内容完整。"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Padding="16,12,20,24"
                              IsVisible="{Binding HasMessages}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChatMessageViewModel">
                                <Grid Margin="8,5" ColumnDefinitions="40,*,40">
                                    <Border Grid.Column="0"
                                            Classes="Avatar AssistantAvatar"
                                            IsVisible="{Binding IsLeftMessage}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   Text="{Binding Initial}" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                MaxWidth="860"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding IsLeftMessage}"
                                                Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Classes="RoleName" Text="{Binding RoleDisplayName}" />
                                            <TextBlock Classes="Metadata" Text="{Binding SequenceText}" />
                                            <TextBlock Classes="Metadata"
                                                       IsVisible="{Binding HasMetadata}"
                                                       Text="{Binding MetadataText}" />
                                        </StackPanel>
                                        <Border Classes="MessageBubbleAssistant">
                                            <StackPanel Spacing="7">
                                                <SelectableTextBlock Classes="MessageContent"
                                                                     IsVisible="{Binding HasContent}"
                                                                     Text="{Binding Content}" />

                                                <Expander Classes="DetailExpander"
                                                          IsVisible="{Binding HasReasoningContent}"
                                                          IsExpanded="False">
                                                    <Expander.Header>
                                                        <TextBlock Classes="Secondary"
                                                                   FontWeight="SemiBold"
                                                                   Text="思考过程" />
                                                    </Expander.Header>
                                                    <Border Classes="ReasoningPanel">
                                                        <SelectableTextBlock Classes="DetailContent"
                                                                             Text="{Binding ReasoningContent}" />
                                                    </Border>
                                                </Expander>

                                                <ItemsControl ItemsSource="{Binding ToolCalls}"
                                                              IsVisible="{Binding HasToolCalls}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ToolCallViewModel">
                                                            <Expander Classes="DetailExpander" Margin="0,2,0,0">
                                                                <Expander.Header>
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock FontWeight="SemiBold"
                                                                                   Text="{Binding DisplayName}" />
                                                                        <TextBlock Classes="Metadata"
                                                                                   IsVisible="{Binding HasDetails}"
                                                                                   Text="{Binding DetailText}" />
                                                                    </StackPanel>
                                                                </Expander.Header>
                                                                <Border Classes="ToolPanel">
                                                                    <StackPanel Spacing="5">
                                                                        <TextBlock Classes="Metadata" Text="调用参数" />
                                                                        <SelectableTextBlock Classes="MonospaceContent"
                                                                                             IsVisible="{Binding HasArguments}"
                                                                                             Text="{Binding Arguments}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                MaxWidth="760"
                                                HorizontalAlignment="Right"
                                                IsVisible="{Binding IsUserMessage}"
                                                Spacing="3">
                                        <StackPanel HorizontalAlignment="Right"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Classes="Metadata" Text="{Binding SequenceText}" />
                                            <TextBlock Classes="Metadata"
                                                       IsVisible="{Binding HasMetadata}"
                                                       Text="{Binding MetadataText}" />
                                            <TextBlock Classes="RoleName" Text="{Binding RoleDisplayName}" />
                                        </StackPanel>
                                        <Border Classes="MessageBubbleUser">
                                            <SelectableTextBlock Classes="UserMessageContent"
                                                                 Text="{Binding Content}" />
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Classes="Avatar UserAvatar"
                                            IsVisible="{Binding IsUserMessage}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   Text="{Binding Initial}" />
                                    </Border>

                                    <Border Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            MaxWidth="760"
                                            HorizontalAlignment="Center"
                                            Classes="MessageBubbleSystem"
                                            IsVisible="{Binding IsSystemMessage}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="Metadata"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RoleDisplayName}" />
                                            <SelectableTextBlock Classes="CenteredMessageContent"
                                                                 Text="{Binding Content}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            MaxWidth="760"
                                            HorizontalAlignment="Center"
                                            Classes="MessageBubbleDeveloper"
                                            IsVisible="{Binding IsDeveloperMessage}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="Metadata"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RoleDisplayName}" />
                                            <SelectableTextBlock Classes="CenteredMessageContent"
                                                                 Text="{Binding Content}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
