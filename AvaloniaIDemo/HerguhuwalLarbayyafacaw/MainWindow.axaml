<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="900"
        x:Class="HerguhuwalLarbayyafacaw.MainWindow"
        Title="HerguhuwalLarbayyafacaw">
   <Grid>
       <Border x:Name="Border1" HorizontalAlignment="Center" VerticalAlignment="Center"
               Width="320"
               Height="320">
           <!-- 宽度高度=Ellipse1.Size + BlurEffect.Radius + 20余量 -->
           <Ellipse x:Name="Ellipse1" Width="150" Height="150" Fill="#3EECFF" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
               <Ellipse.Effect> 
                   <BlurEffect Radius="150"/> 
               </Ellipse.Effect> 
           </Ellipse>
       </Border>
 
   </Grid>
</Window>
