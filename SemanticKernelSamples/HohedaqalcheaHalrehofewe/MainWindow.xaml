<Window x:Class="HohedaqalcheaHalrehofewe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="谁是卧底 - 豆包对话演示"
        Width="1460"
        Height="940"
        MinWidth="1260"
        MinHeight="800">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="谁是卧底 · 玩家 + AI 协同对局" />
                    <TextBlock Margin="0,10,0,0" Style="{StaticResource SubtleTextStyle}" Text="保留豆包推理流输出，让一名真人玩家接管角色，并通过 MVVM 数据驱动界面状态。" TextWrapping="Wrap" />
                    <Border Margin="0,18,0,0" Padding="14,12" Background="#80FFFFFF" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="当前状态" />
                            <TextBlock Margin="0,6,0,0" FontSize="15" FontWeight="SemiBold" Text="{Binding StatusText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Grid.Column="1" Width="320" Margin="20,0,0,0" Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="你的角色信息" />
                        <TextBlock Margin="0,10,0,0" FontSize="18" FontWeight="Bold" Text="{Binding PlayerWordText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0" Style="{StaticResource SubtleTextStyle}" Text="轮到你时，下方输入区会自动进入可编辑状态。" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <GroupBox Grid.Row="2" Header="游戏配置">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="API Key 文件路径" />
                    <TextBox Text="{Binding ApiKeyFilePath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="部署 Id" />
                    <TextBox Text="{Binding DeploymentId, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="玩家人数" />
                    <TextBox Text="{Binding PlayerCountText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="平民词" />
                    <TextBox Text="{Binding MainWord, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="卧底词" />
                    <TextBox Text="{Binding SpyWord, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="玩家角色编号" />
                    <TextBox Text="{Binding HumanPlayerIndexText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditConfiguration}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Command="{Binding StartNewGameCommand}" Content="开始新局" />
                    <Button Command="{Binding StartNextRoundCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="开始下一回合" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="玩家面板">
                <ListBox ItemsSource="{Binding Players}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16" CornerRadius="16" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding ControllerText}" />
                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="{Binding StatusText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Padding="10,6" Background="#14000000" CornerRadius="999">
                                        <TextBlock FontSize="11" FontWeight="Bold" Text="{Binding RoleBadgeText}" />
                                    </Border>
                                </Grid>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Background" Value="#FFEFF3FF" />
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="对话时间线">
                <ListBox x:Name="TimelineListBox" ItemsSource="{Binding Timeline}" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="18" CornerRadius="18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Header}" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="System"><Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" /><Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Reasoning"><Setter Property="Background" Value="#FFF1EDFF" /><Setter Property="BorderBrush" Value="#FFC6B8FF" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="AiSpeech"><Setter Property="Background" Value="#FFF7FBFF" /><Setter Property="BorderBrush" Value="#FFB8D4FF" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="AiVote"><Setter Property="Background" Value="#FFFFF6EA" /><Setter Property="BorderBrush" Value="#FFF7C47A" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="PlayerSpeech"><Setter Property="Background" Value="#FFECF8F4" /><Setter Property="BorderBrush" Value="#FF8CD1B9" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="PlayerVote"><Setter Property="Background" Value="#FFECF8F4" /><Setter Property="BorderBrush" Value="#FF8CD1B9" /></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <Border Grid.Row="6" Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="22" FontWeight="Bold" Text="玩家输入区" />
                <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding UserPromptText}" TextWrapping="Wrap" />
                <TextBox Grid.Row="2" Margin="0,16,0,0" AcceptsReturn="True" IsEnabled="{Binding IsAwaitingUserInput}" MinHeight="130" Text="{Binding PendingUserInput, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding SubmitInputCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <StackPanel Grid.Row="3" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding SubmitInputCommand}" Content="提交输入" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
