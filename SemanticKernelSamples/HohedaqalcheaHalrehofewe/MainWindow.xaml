<Window x:Class="HohedaqalcheaHalrehofewe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HohedaqalcheaHalrehofewe"
        mc:Ignorable="d"
        Title="谁是卧底 - 豆包对话演示"
        Width="1440"
        Height="920"
        MinWidth="1200"
        MinHeight="760">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="#FFF8FAFC"
                BorderBrush="#FFD0D7DE"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="3"
                           Margin="0,0,0,12"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="游戏配置" />

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,8">
                    <TextBlock Margin="0,0,0,4" Text="API Key 文件路径" />
                    <TextBox x:Name="ApiKeyFilePathTextBox"
                             Text="{Binding ApiKeyFilePath, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,12,8">
                    <TextBlock Margin="0,0,0,4" Text="部署 Id" />
                    <TextBox x:Name="DeploymentIdTextBox"
                             Text="{Binding DeploymentId, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,0,8">
                    <TextBlock Margin="0,0,0,4" Text="当前状态" />
                    <Border Padding="10,8" Background="#FFFFFFFF" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="4"><TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" /></Border>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,12,8">
                    <TextBlock Margin="0,0,0,4" Text="平民词" />
                    <TextBox x:Name="MainWordTextBox"
                             Text="{Binding MainWord, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,0,12,8">
                    <TextBlock Margin="0,0,0,4" Text="卧底词" />
                    <TextBox x:Name="SpyWordTextBox"
                             Text="{Binding SpyWord, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="2"
                            Margin="0,0,0,8">
                    <TextBlock Margin="0,0,0,4" Text="你的词语" />
                    <Border Padding="10,8" Background="#FFFFFFFF" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="4"><TextBlock Text="{Binding PlayerWordText}" TextWrapping="Wrap" /></Border>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="0,0,12,0">
                    <StackPanel Width="160" Margin="0,0,12,0">
                        <TextBlock Margin="0,0,0,4" Text="玩家人数" />
                        <TextBox x:Name="PlayerCountTextBox"
                                 Text="{Binding PlayerCountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="160">
                        <TextBlock Margin="0,0,0,4" Text="玩家角色编号" />
                        <TextBox x:Name="HumanPlayerIndexTextBox"
                                 Text="{Binding HumanPlayerIndexText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button x:Name="StartNewGameButton"
                            Width="140"
                            Margin="0,0,12,0"
                            Padding="12,8"
                            Click="OnStartNewGameClick"
                            Content="开始新局" />
                    <Button x:Name="StartNextRoundButton"
                            Width="140"
                            Margin="0,0,12,0"
                            Padding="12,8"
                            Click="OnStartNextRoundClick"
                            Content="开始下一回合" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="玩家列表">
                <ListBox ItemsSource="{Binding Players}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FFF8FAFC"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding ControllerText}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#FF375A7F"
                                               Text="{Binding StatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="对话时间线">
                <ListBox x:Name="TimelineListBox"
                         ItemsSource="{Binding Timeline}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="#FFFFFFFF"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Header}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding Content}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2"
                Padding="16"
                Background="#FFF8FAFC"
                BorderBrush="#FFD0D7DE"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="玩家输入区" />

                <TextBlock Grid.Row="1"
                           Margin="0,12,0,8"
                           Text="{Binding UserPromptText}"
                           TextWrapping="Wrap" />

                <TextBox x:Name="UserInputTextBox"
                         Grid.Row="1"
                         Margin="0,48,0,0"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         KeyDown="OnUserInputTextBoxKeyDown"
                         Text="{Binding PendingUserInput, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="2"
                            Margin="0,12,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="SubmitInputButton"
                            Width="140"
                            Padding="12,8"
                            Click="OnSubmitInputClick"
                            Content="提交输入" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
