<UserControl x:Class="DeepSeekWpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="26"
                       FontWeight="SemiBold"
                       Text="设置界面" />
            <TextBlock Margin="0,8,0,20"
                       Foreground="#FF6B7280"
                       Text="配置缓存目录、数据目录、日志目录和模型接入信息。保存后将返回主界面。" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="20"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="缓存路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding CachePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding CachePath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="数据路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding DataPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding DataPath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="日志路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding LogPath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="模型名称" />
                    <TextBox Margin="0,8,0,16"
                             Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock FontWeight="SemiBold" Text="API 地址" />
                    <TextBox Margin="0,8,0,16"
                             Text="{Binding ApiAddress, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock FontWeight="SemiBold" Text="API Key" />
                    <TextBox Margin="0,8,0,16"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Foreground="#FF6B7280" Text="{Binding StatusMessage}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,12,0"
                    Command="{Binding RestoreDefaultsCommand}"
                    Content="恢复默认" />
            <Button Command="{Binding SaveSettingsCommand}" Content="保存设置" />
        </StackPanel>
    </Grid>
</UserControl>
