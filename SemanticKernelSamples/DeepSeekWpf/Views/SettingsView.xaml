<UserControl x:Class="DeepSeekWpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="26"
                       FontWeight="SemiBold"
                       Text="设置界面" />
            <TextBlock Margin="0,8,0,20"
                       Foreground="#FF6B7280"
                       Text="管理应用目录和 AgentApiManagerConfiguration。API Key 仅保存在用户配置文件中。" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="20"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="缓存路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding CachePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding CachePath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="数据路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding DataPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding DataPath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="日志路径" />
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding LogPath}"
                                Content="打开目录" />
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="Agent API 配置文件" />
                    <TextBox Margin="0,8,0,12"
                             IsReadOnly="True"
                             Text="{Binding AgentConfigurationPath}" />
                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <Button Margin="0,0,12,0"
                                Command="{Binding OpenAgentConfigurationCommand}"
                                Content="编辑配置文件" />
                        <Button Command="{Binding ValidateAgentConfigurationCommand}"
                                Content="校验配置" />
                    </StackPanel>

                    <TextBlock Margin="0,0,0,16"
                               Foreground="#FF6B7280"
                               TextWrapping="Wrap"
                               Text="配置文件支持多个 OpenAI 协议终结点和模型。修改配置或日志目录后请重启应用，避免运行期重复注册模型。" />

                    <TextBlock Foreground="#FF6B7280" Text="{Binding StatusMessage}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,12,0"
                    Command="{Binding RestoreDefaultsCommand}"
                    Content="恢复默认" />
            <Button Command="{Binding SaveSettingsCommand}" Content="保存设置" />
        </StackPanel>
    </Grid>
</UserControl>
