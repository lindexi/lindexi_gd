<UserControl x:Class="DeepSeekWpf.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="历史会话" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="#FF6B7280"
                               Text="异步加载历史对话，可继续之前的聊天。" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,6,0"
                                Command="{Binding NewChatCommand}"
                                Content="新建会话" />
                        <Button Grid.Column="1"
                                Margin="6,0,0,0"
                                Command="{Binding DeleteSelectedChatCommand}"
                                Content="删除会话" />
                    </Grid>

                    <Button Command="{Binding ReloadSessionsCommand}" Content="刷新会话列表" />
                </StackPanel>

                <ListBox Margin="0,16,0,0"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FFF9FAFB"
                                    BorderBrush="#FFE5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="#FF6B7280"
                                               Text="{Binding UpdatedAt, StringFormat=更新时间：{0:yyyy-MM-dd HH:mm}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="#FF9CA3AF"
                                               Text="{Binding Messages.Count, StringFormat=消息数：{0}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="{Binding CurrentSessionTitle}" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#FF6B7280"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     Margin="0,0,0,12"
                     ItemsSource="{Binding CurrentMessages}"
                     SelectedItem="{Binding SelectedMessage}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="White"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Role}" />
                                        <TextBlock Margin="12,0,0,0"
                                                   Foreground="#FF9CA3AF"
                                                   Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    </StackPanel>

                                    <Button DockPanel.Dock="Right"
                                            Command="{Binding DataContext.BeginInlineEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Content="编辑">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Padding" Value="10,4" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DockPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            Background="#FFEEF2FF"
                                            BorderBrush="#FFC7D2FE"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasThoughtContent}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="思考内容" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding ThoughtContent}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10"
                                            Background="#FFF9FAFB"
                                            BorderBrush="#FFE5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="消息内容" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Content}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            Background="#FFEEF2FF"
                                            BorderBrush="#FFC7D2FE"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="思考内容" />
                                            <TextBox Margin="0,8,0,0"
                                                     AcceptsReturn="True"
                                                     Text="{Binding EditingThoughtContent, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10"
                                            Background="#FFF9FAFB"
                                            BorderBrush="#FFE5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="消息内容" />
                                            <TextBox Margin="0,8,0,0"
                                                     AcceptsReturn="True"
                                                     Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,10,0,0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,12,0"
                                                Command="{Binding DataContext.CancelInlineEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Content="取消" />
                                        <Button Command="{Binding DataContext.SaveInlineEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Content="保存" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="输入消息" />
                    <TextBox MinHeight="120"
                             Margin="0,8,0,0"
                             AcceptsReturn="True"
                             Text="{Binding PendingUserMessage, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Foreground="#FF6B7280" Text="悬停消息卡片时显示编辑按钮，编辑后直接在原消息位置保存。" />
                    <TextBlock Foreground="#FF9CA3AF" Text="AI 回复会分开显示思考内容和消息内容。" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Margin="12,0,0,0"
                            Command="{Binding StopCommand}"
                            Content="停止" />
                    <Button Margin="12,0,0,0"
                            Command="{Binding SendMessageCommand}"
                            Content="发送" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
