<UserControl x:Class="DeepSeekWpf.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="历史会话" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="#FF6B7280"
                               Text="当前运行实例中的会话。聊天历史会同步写入数据目录。" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,6,0"
                                Command="{Binding NewChatCommand}"
                                Content="新建会话" />
                        <Button Grid.Column="1"
                                Margin="6,0,0,0"
                                Command="{Binding DeleteSelectedChatCommand}"
                                Content="删除会话" />
                    </Grid>

                </StackPanel>

                <ListBox Margin="0,16,0,0"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FFF9FAFB"
                                    BorderBrush="#FFE5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="#FF6B7280"
                                               Text="{Binding StartedTime, StringFormat=开始时间：{0:yyyy-MM-dd HH:mm}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="#FF9CA3AF"
                                               Text="{Binding ChatMessages.Count, StringFormat=消息数：{0}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="{Binding CurrentSessionTitle}" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#FF6B7280"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     Margin="0,0,0,12"
                     ItemsSource="{Binding CurrentMessages}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="White"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal">
                                         <TextBlock FontWeight="SemiBold" Text="{Binding Author}" />
                                        <TextBlock Margin="12,0,0,0"
                                                   Foreground="#FF9CA3AF"
                                                    Text="{Binding CreatedTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    </StackPanel>
                                </DockPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            Background="#FFEEF2FF"
                                            BorderBrush="#FFC7D2FE"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasReason}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="思考内容" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                        Text="{Binding Reason}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10"
                                            Background="#FFF9FAFB"
                                            BorderBrush="#FFE5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="消息内容" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Content}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="12"
                                                       Foreground="#FF6B7280"
                                                       Text="{Binding UsageSummaryText}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="输入消息" />
                    <TextBox MinHeight="120"
                             Margin="0,8,0,0"
                             AcceptsReturn="True"
                             Text="{Binding PendingUserMessage, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Foreground="#FF6B7280" Text="会话由 AgentLib 管理，AI 回复会流式显示思考内容和正文。" />
                    <TextBlock Foreground="#FF9CA3AF" Text="日志与历史快照保存在设置页所示目录。" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Margin="12,0,0,0"
                            Command="{Binding StopCommand}"
                            Content="停止" />
                    <Button Margin="12,0,0,0"
                            Command="{Binding SendMessageCommand}"
                            Content="发送" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
