<UserControl x:Class="DeepSeekWpf.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="历史会话" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="#FF6B7280"
                               Text="新建、删除和继续之前的聊天。" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,6,0"
                                Command="{Binding NewChatCommand}"
                                Content="新建会话" />
                        <Button Grid.Column="1"
                                Margin="6,0,0,0"
                                Command="{Binding DeleteSelectedChatCommand}"
                                Content="删除会话" />
                    </Grid>

                    <Button Command="{Binding ReloadSessionsCommand}" Content="刷新会话列表" />
                </StackPanel>

                <ListBox Margin="0,16,0,0"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FFF9FAFB"
                                    BorderBrush="#FFE5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="#FF6B7280"
                                               Text="{Binding UpdatedAt, StringFormat=更新时间：{0:yyyy-MM-dd HH:mm}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="#FF9CA3AF"
                                               Text="{Binding Messages.Count, StringFormat=消息数：{0}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="{Binding CurrentSessionTitle}" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#FF6B7280"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     Margin="0,0,0,12"
                     ItemsSource="{Binding CurrentMessages}"
                     SelectedItem="{Binding SelectedMessage}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="#FFF9FAFB"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Role}" />
                                    <TextBlock DockPanel.Dock="Right"
                                               FontSize="12"
                                               Foreground="#FF6B7280"
                                               Text="{Binding CreatedAt, StringFormat={}{0:HH:mm:ss}}" />
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding Content}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="输入消息" />
                    <TextBox MinHeight="100"
                             Margin="0,8,0,0"
                             AcceptsReturn="True"
                             Text="{Binding PendingUserMessage, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FF6B7280"
                           Text="选择历史会话即可继续聊天，选择消息即可在右侧编辑。" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Margin="12,0,0,0"
                            Command="{Binding StopCommand}"
                            Content="停止" />
                    <Button Margin="12,0,0,0"
                            Command="{Binding SendMessageCommand}"
                            Content="发送" />
                </StackPanel>
            </DockPanel>
        </Grid>

        <Border Grid.Column="2"
                Padding="16"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="消息编辑器" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#FF6B7280"
                           Text="{Binding SelectedMessageRoleDisplay, StringFormat=角色：{0}}" />
                <TextBlock Margin="0,4,0,12"
                           Foreground="#FF6B7280"
                           Text="{Binding SelectedMessageTimeDisplay, StringFormat=时间：{0}}" />
                <TextBox MinHeight="320"
                         AcceptsReturn="True"
                         Text="{Binding EditableMessageContent, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <Button Width="120"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding SaveMessageEditCommand}"
                        Content="保存编辑" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
