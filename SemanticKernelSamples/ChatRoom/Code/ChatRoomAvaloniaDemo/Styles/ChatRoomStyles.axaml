<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

  <!-- ============================================
       主题色定义
       ============================================ -->
  <Styles.Resources>
    <!-- 主色调 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#4A90D9" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#6BA5E7" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3A7BC8" />

    <!-- 辅助色 -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#7C8CA0" />
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="#A0B0C0" />

    <!-- 背景色 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#282840" />
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="#32325A" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#3E3E60" />

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0F0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0C0" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6E6E8A" />

    <!-- 状态色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FF9800" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F44336" />
    <SolidColorBrush x:Key="InfoBrush" Color="#2196F3" />

    <!-- 角色头像颜色池 -->
    <SolidColorBrush x:Key="AvatarColor1" Color="#FF6B6B" />
    <SolidColorBrush x:Key="AvatarColor2" Color="#4ECDC4" />
    <SolidColorBrush x:Key="AvatarColor3" Color="#45B7D1" />
    <SolidColorBrush x:Key="AvatarColor4" Color="#96CEB4" />
    <SolidColorBrush x:Key="AvatarColor5" Color="#FFEAA7" />
    <SolidColorBrush x:Key="AvatarColor6" Color="#DDA0DD" />

    <!-- 共用圆角 -->
    <CornerRadius x:Key="DefaultCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">10</CornerRadius>

    <!-- 共用间距 -->
    <Thickness x:Key="DefaultPadding">12,8</Thickness>
    <Thickness x:Key="SmallPadding">8,4</Thickness>
    <Thickness x:Key="LargePadding">16,12</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,12</Thickness>
  </Styles.Resources>

  <!-- ============================================
       基础控件样式
       ============================================ -->

  <!-- TextBlock 默认样式 -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- 标题 TextBlock -->
  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Button 主样式 -->
  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    <Setter Property="Padding" Value="{StaticResource DefaultPadding}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
  </Style>

  <!-- 次要按钮 -->
  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{StaticResource SecondaryLightBrush}" />
  </Style>

  <!-- 危险按钮 -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.danger:pointerover">
    <Setter Property="Background" Value="#E53935" />
  </Style>

  <!-- 小尺寸按钮 -->
  <Style Selector="Button.small">
    <Setter Property="Padding" Value="{StaticResource SmallPadding}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
  </Style>

  <!-- 透明/幽灵按钮 -->
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- TextBox 样式 -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    <Setter Property="Padding" Value="{StaticResource DefaultPadding}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource SecondaryLightBrush}" />
  </Style>

  <!-- 多行 TextBox（聊天输入区） -->
  <Style Selector="TextBox.multiline">
    <Setter Property="AcceptsReturn" Value="True" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MinHeight" Value="48" />
    <Setter Property="MaxHeight" Value="120" />
  </Style>

  <!-- ListBox 样式 -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <!-- ListBoxItem 样式 -->
  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="ListBoxItem:selected:focus">
    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
  </Style>

  <!-- ScrollViewer 样式 -->
  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ScrollBar 样式 -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ScrollBar /template/ RepeatButton">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <!-- Separator 样式 -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <!-- ============================================
       区域面板样式
       ============================================ -->

  <!-- 区块面板 -->
  <Style Selector="Border.section">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <!-- 聊天消息气泡 - 角色 -->
  <Style Selector="Border.bubble-assistant">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource LargeCornerRadius}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <!-- 聊天消息气泡 - 人类 -->
  <Style Selector="Border.bubble-human">
    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource LargeCornerRadius}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <!-- 聊天消息气泡 - 系统 -->
  <Style Selector="Border.bubble-system">
    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <!-- 角色头像圆形 -->
  <Style Selector="Border.avatar">
    <Setter Property="CornerRadius" Value="100" />
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- 输入区面板 -->
  <Style Selector="Border.input-panel">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <!-- 侧栏头部 -->
  <Style Selector="Border.sidebar-header">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
    <Setter Property="Padding" Value="16,12" />
  </Style>

  <!-- ============================================
       设计时数据支持
       ============================================ -->
  <Design.DataContext>
    <x:Null />
  </Design.DataContext>

</Styles>