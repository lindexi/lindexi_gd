<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChatRoom.AvaloniaShell.ViewModels"
             x:Class="ChatRoom.AvaloniaShell.Views.RoleEditView"
             x:DataType="vm:RoleEditViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Background="{StaticResource BackgroundBrush}">
        <!-- 标题栏 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="16,12">
            <Button Classes="Flat" Content="← 返回"
                    Command="{Binding CancelCommand}" />
            <TextBlock Grid.Column="1" Text="{Binding TitleText}"
                       Classes="Title" HorizontalAlignment="Center" />
            <Button Grid.Column="2" Classes="Primary" Content="保存"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding !IsBusy}" />
        </Grid>

        <!-- 编辑表单 -->
        <ScrollViewer Grid.Row="1" Padding="16,0">
            <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Stretch">
                <Border Classes="Card" Padding="12" IsVisible="{Binding HasErrorMessage}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- 基本信息 -->
                <Border Classes="Card" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="基本信息" Classes="Title" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="角色名称" Classes="Subtitle" />
                            <TextBox Classes="Rounded" Text="{Binding RoleName}"
                                     PlaceholderText="输入角色名称" />
                        </StackPanel>

                        <CheckBox Content="是否人类角色" IsChecked="{Binding IsHuman}"
                                  IsEnabled="{Binding CanEditIsHuman}" />
                    </StackPanel>
                </Border>

                <!-- 系统提示词 -->
                <Border Classes="Card" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="系统提示词" Classes="Title" />
                        <TextBox Classes="Rounded" Text="{Binding SystemPrompt}"
                                 PlaceholderText="角色人设/系统提示词"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="100" />
                    </StackPanel>
                </Border>

                <!-- 模型配置 -->
                <Border Classes="Card" Padding="16" IsVisible="{Binding !IsHuman}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="模型配置" Classes="Title" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="模型提供商 ID" Classes="Subtitle" />
                            <TextBox Classes="Rounded" Text="{Binding ModelProviderId}"
                                     PlaceholderText="留空使用默认" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="模型 ID" Classes="Subtitle" />
                            <TextBox Classes="Rounded" Text="{Binding ModelId}"
                                     PlaceholderText="留空使用默认" />
                        </StackPanel>

                        <!-- 当前实际生效的模型 -->
                        <Border Background="{StaticResource SurfaceVariantBrush}" CornerRadius="6" Padding="10,8"
                                IsVisible="{Binding !!CurrentEffectiveModel}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="当前生效模型" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding CurrentEffectiveModel}"
                                           Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 参与模式 -->
                <Border Classes="Card" Padding="16" IsVisible="{Binding !IsHuman}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="参与模式" Classes="Title" />
                        <ComboBox ItemsSource="{Binding ParticipationModeOptions}"
                                  SelectedItem="{Binding ParticipationMode}" />
                    </StackPanel>
                </Border>

                <!-- 角色记忆 -->
                <Border Classes="Card" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="角色记忆（可选）" Classes="Title" />
                        <TextBox Classes="Rounded" Text="{Binding MemoryContent}"
                                 PlaceholderText="角色的长期记忆内容"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="80" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
