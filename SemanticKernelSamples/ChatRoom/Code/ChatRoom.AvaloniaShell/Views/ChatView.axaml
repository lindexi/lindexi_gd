<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChatRoom.AvaloniaShell.ViewModels"
             xmlns:conv="using:ChatRoom.AvaloniaShell.Converters"
             x:Class="ChatRoom.AvaloniaShell.Views.ChatView"
             x:DataType="vm:ChatViewModel">

    <UserControl.Resources>
        <conv:RoleInitialConverter x:Key="RoleInitial" />
        <conv:RoleColorConverter x:Key="RoleColor" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 顶部状态栏 -->
        <Border Grid.Row="0" Padding="12,8" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="聊天室" Classes="Title" />
                <TextBlock Text="{Binding CurrentSpeakerName}" Classes="Subtitle"
                           IsVisible="{Binding IsRunning}" />
                <TextBlock Text="正在发言..." Classes="Subtitle"
                           Foreground="{StaticResource WarningBrush}"
                           IsVisible="{Binding IsRunning}" />
            </StackPanel>
        </Border>

        <!-- 消息列表 -->
        <ScrollViewer Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="8">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageItemViewModel">
                            <Grid Margin="8,4" ColumnDefinitions="40,*,40">
                                <!-- AI 消息：头像在左 -->
                                <Border Grid.Column="0" Classes="Avatar"
                                        Background="{Binding SenderRoleName, Converter={StaticResource RoleColor}}"
                                        IsVisible="{Binding IsAiMessage}">
                                    <TextBlock Text="{Binding Initial}" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>

                                <!-- AI 消息内容 -->
                                <StackPanel Grid.Column="1" IsVisible="{Binding IsAiMessage}" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding SenderRoleName}" Classes="RoleName" />
                                        <TextBlock Text="{Binding TimeText}" Classes="Timestamp" />
                                        <TextBlock Text="正在输入..." Classes="Timestamp"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   IsVisible="{Binding IsStreaming}" />
                                    </StackPanel>
                                    <Border Classes="MessageBubbleAI" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   MaxWidth="500" />
                                    </Border>
                                </StackPanel>

                                <!-- 人类消息：内容靠右 -->
                                <StackPanel Grid.Column="1" IsVisible="{Binding IsHumanMessage}" Spacing="2"
                                            HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TimeText}" Classes="Timestamp" />
                                        <TextBlock Text="{Binding SenderRoleName}" Classes="RoleName" />
                                    </StackPanel>
                                    <Border Classes="MessageBubbleHuman" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextOnPrimaryBrush}"
                                                   MaxWidth="500" />
                                    </Border>
                                </StackPanel>

                                <!-- 人类头像 -->
                                <Border Grid.Column="2" Classes="Avatar"
                                        Background="{StaticResource PrimaryBrush}"
                                        IsVisible="{Binding IsHumanMessage}">
                                    <TextBlock Text="{Binding Initial}" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>

                                <!-- 系统消息：居中 -->
                                <Border Grid.Column="0" Grid.ColumnSpan="3"
                                        Classes="MessageBubbleSystem" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsSystemMessage}">
                                    <TextBlock Text="{Binding Content}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" MaxWidth="400" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

        <!-- 输入栏 -->
        <Border Grid.Row="2" Padding="12,8" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Classes="Rounded"
                         Text="{Binding InputText}"
                         Watermark="输入消息，@角色名 提及特定角色..."
                         IsEnabled="{Binding !IsRunning}"
                         AcceptsReturn="False" />
                <Button Grid.Column="1" Classes="Primary" Content="{Binding SendButtonText}"
                        Margin="8,0,0,0"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding CanSend}"
                        IsVisible="{Binding !IsRunning}" />
                <Button Grid.Column="1" Classes="Danger" Content="停止"
                        Margin="8,0,0,0"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding CanStop}"
                        IsVisible="{Binding IsRunning}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
