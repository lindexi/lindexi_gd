<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChatRoom.AvaloniaShell.ViewModels"
             xmlns:conv="using:ChatRoom.AvaloniaShell.Converters"
             x:Class="ChatRoom.AvaloniaShell.Views.RoleLobbyView"
             x:DataType="vm:RoleLobbyViewModel">

    <UserControl.Resources>
        <conv:RoleInitialConverter x:Key="RoleInitial" />
        <conv:RoleColorConverter x:Key="RoleColor" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{StaticResource BackgroundBrush}">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="16,12">
            <Button Classes="Flat" Content="← 返回" Command="{Binding BackCommand}" />
            <TextBlock Grid.Column="1" Text="角色大厅" Classes="Title" HorizontalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1" Classes="Card" Padding="16" Margin="16,0" IsVisible="{Binding IsPromotePanelVisible}">
            <StackPanel Spacing="12">
                <TextBlock Text="提升角色到大厅" Classes="Title" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="来源角色" Classes="Subtitle" />
                        <ComboBox ItemsSource="{Binding SessionRoles}" SelectedValue="{Binding PromoteSelectedRoleId}" SelectedValueBinding="{Binding RoleId}" DisplayMemberBinding="{Binding RoleName}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="分类" Classes="Subtitle" />
                        <TextBox Classes="Rounded" Text="{Binding PromoteCategory}" PlaceholderText="如：开发、产品、通用" />
                    </StackPanel>
                </Grid>
                <StackPanel Spacing="4">
                    <TextBlock Text="模板名称" Classes="Subtitle" />
                    <TextBox Classes="Rounded" Text="{Binding PromoteName}" PlaceholderText="输入模板名称" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="描述" Classes="Subtitle" />
                    <TextBox Classes="Rounded" Text="{Binding PromoteDescription}" PlaceholderText="一句话描述角色用途" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="标签（逗号分隔）" Classes="Subtitle" />
                    <TextBox Classes="Rounded" Text="{Binding PromoteTags}" PlaceholderText="如：架构, 系统设计" />
                </StackPanel>
                <TextBlock Text="{Binding PromoteErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" IsVisible="{Binding HasPromoteErrorMessage}" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Classes="Flat" Content="取消" Command="{Binding CancelPromoteCommand}" />
                    <Button Classes="Primary" Content="提升到大厅" Command="{Binding ConfirmPromoteCommand}" IsEnabled="{Binding !IsBusy}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="16,8">
            <TextBox Classes="Rounded" Text="{Binding SearchText}" PlaceholderText="搜索模板..." />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
                <TextBlock Text="分类:" Classes="Subtitle" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" PlaceholderText="全部" MinWidth="120" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="3" Padding="16,0">
            <ItemsControl ItemsSource="{Binding Templates}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoleTemplateCardViewModel">
                        <Border Classes="Card" Padding="16,12" Margin="8" Width="200">
                            <StackPanel Spacing="8">
                                <Border Width="48" Height="48" CornerRadius="24" Background="{Binding Name, Converter={StaticResource RoleColor}}" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Initial}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" />
                                </Border>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Description}" Classes="Subtitle" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding TagsDisplay}" Classes="Subtitle" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding ModelDisplay}" Classes="Subtitle" HorizontalAlignment="Center" />
                                <Button Classes="Primary" Content="+ 添加到当前会话" HorizontalAlignment="Stretch" Command="{Binding $parent[ItemsControl].((vm:RoleLobbyViewModel)DataContext).AddToSessionCommand}" CommandParameter="{Binding}" />
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <Button Classes="Flat" Content="✏" Padding="6,4" FontSize="14" Command="{Binding $parent[ItemsControl].((vm:RoleLobbyViewModel)DataContext).EditTemplateCommand}" CommandParameter="{Binding}" />
                                    <Button Classes="Flat" Content="🗑" Padding="6,4" FontSize="14" Command="{Binding $parent[ItemsControl].((vm:RoleLobbyViewModel)DataContext).DeleteTemplateCommand}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
