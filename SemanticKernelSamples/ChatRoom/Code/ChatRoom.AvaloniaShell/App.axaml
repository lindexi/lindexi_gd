<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChatRoom.AvaloniaShell.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://ChatRoom.AvaloniaShell/Styles/Colors.axaml" />
        <StyleInclude Source="avares://ChatRoom.AvaloniaShell/Styles/Controls.axaml" />
        <StyleInclude Source="avares://ChatRoom.AvaloniaShell/Styles/MessageBubble.axaml" />
    </Application.Styles>
</Application>