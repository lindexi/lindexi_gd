<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.LeftSidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             Background="White"
             d:DataContext="{d:DesignInstance Type=viewModels:CoursewareSlideWorkspaceViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760"
             d:DesignWidth="240"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <Style x:Key="SlideListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type viewModels:CoursewareSlideItemViewModel}">
            <StackPanel HorizontalAlignment="Center">
                <Border x:Name="ThumbnailBorder"
                        Width="184"
                        Height="118"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="2"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Grid Background="#F1F5F9">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" Background="White">
                                <Image Source="{Binding SourceScreenshotFilePath, Converter={x:Static converters:FilePathToImageSourceConverter.Instance}}"
                                       Stretch="Uniform" />
                                <Image Source="{Binding PreviewImage, Converter={x:Static converters:PreviewImageToImageSourceConverter.Instance}}"
                                       Stretch="Uniform" />
                                <TextBlock Text="等待页面内容"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasAnyPreviewImage, Converter={x:Static converters:InverseBooleanToVisibilityConverter.Instance}}" />
                            </Grid>
                        </Viewbox>
                        <Border Width="20"
                                Height="20"
                                Margin="0,5,5,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#FFF3D6"
                                 CornerRadius="10"
                                 ToolTip="{Binding WarningSummary}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="!" Foreground="#C57900" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="20"
                                Height="20"
                                Margin="0,5,5,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="#FDE8E8"
                                CornerRadius="10"
                                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="{Binding ErrorMessage}">
                            <TextBlock Text="×" Foreground="#B42318" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
                <DockPanel Width="184" Margin="0,5,0,0">
                    <TextBlock DockPanel.Dock="Right" Text="{Binding NumberText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                </DockPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource PrimaryBlueBrush}" FontSize="10" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding SlideId}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="9" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="184" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ThumbnailBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,12">
            <TextBlock Text="课件页面" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="16" />
            <TextBlock Text="{Binding CoursewareTitle}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
            <TextBlock Text="{Binding SummaryText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0" />
        </StackPanel>

        <ListBox x:Name="SlideListBox"
                 ItemsSource="{Binding Slides}"
                 SelectedItem="{Binding SelectedSlide, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource SlideListBoxItemStyle}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="12,0,12,12" />
    </DockPanel>
</UserControl>
