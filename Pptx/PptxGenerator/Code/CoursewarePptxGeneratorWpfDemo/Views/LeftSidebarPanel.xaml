<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.LeftSidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CoursewarePptxGeneratorWpfDemo.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:CoursewarePptxGeneratorWpfDemo.Models"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             Background="White"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760"
             d:DesignWidth="240"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SlideListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type models:CoursewareSlideItem}">
            <StackPanel HorizontalAlignment="Center">
                <Border x:Name="ThumbnailBorder"
                        Width="170"
                        Height="110"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="2"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Grid Background="#f8fafc">
                        <Image Source="{Binding SourceScreenshotFilePath, Converter={x:Static converters:FilePathToImageSourceConverter.Instance}}"
                               Stretch="UniformToFill" />
                        <Image Source="{Binding SlideChatManager.PreviewImage, Converter={x:Static converters:PreviewImageToImageSourceConverter.Instance}}"
                               Stretch="UniformToFill" />
                        <Border Width="76"
                                Height="48"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSourceScreenshot}" Value="False" />
                                                <Condition Binding="{Binding SlideChatManager.PreviewImage}" Value="{x:Null}" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="Empty"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSourceScreenshot}" Value="False" />
                                                <Condition Binding="{Binding SlideChatManager.PreviewImage}" Value="{x:Null}" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
                <TextBlock Text="{Binding SlideId, StringFormat=Id: {0}}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="170" />
                <TextBlock Text="{Binding Status}"
                           Foreground="{StaticResource PrimaryBlueBrush}"
                           FontSize="10"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ThumbnailBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Ellipse Width="28" Height="28">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0" />
                            <GradientStop Color="#8B5CF6" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="SlideML Lab"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>

            <Button Command="{Binding AddPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="0,8">
                <TextBlock Text="+ 添加空页面" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
            </Button>
        </StackPanel>

        <ListBox x:Name="SlideListBox"
                 ItemsSource="{Binding Slides}"
                 SelectedItem="{Binding SelectedSlide, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource SlideListBoxItemStyle}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="12,0,12,12" />
    </DockPanel>
</UserControl>
