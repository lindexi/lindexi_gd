<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.SlideWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             xmlns:views="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views"
             d:DataContext="{d:DesignInstance Type=viewModels:CoursewareWorkspaceViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="1000"
             d:DesignWidth="1720"
             Background="{StaticResource LightBackgroundBrush}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,10">
            <DockPanel>
                <Button x:Name="BackToAnalysisButton"
                        DockPanel.Dock="Left"
                        Content="{StaticResource BackToThemeSuggestionText}"
                        Command="{Binding BackToAnalysisCommand}"
                        Style="{StaticResource AnalysisSecondaryButtonStyle}"
                        AutomationProperties.Name="{StaticResource BackToThemeSuggestionAutomationText}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SlideWorkspace.SummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0" />
                <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SlideWorkspace.CoursewareTitle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="17"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding SlideWorkspace.ThemeTitle, StringFormat=页面美化主题：{0}}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <views:LeftSidebarPanel Grid.Column="0" DataContext="{Binding SlideWorkspace}" />
            <views:MainContentPanel Grid.Column="1" DataContext="{Binding SlideWorkspace}" />
            <views:CopilotPanel Grid.Column="2" DataContext="{Binding SlideWorkspace}" />
        </Grid>
    </Grid>
</UserControl>
