<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.CopilotPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:agent="clr-namespace:AgentLib.Model;assembly=AgentLib"
             xmlns:converters="clr-namespace:CoursewarePptxGeneratorWpfDemo.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System.IO;assembly=System.Runtime"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             xmlns:views="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views"
             Background="{StaticResource LightBackgroundBrush}"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760"
             d:DesignWidth="420"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <views:CopilotChatMessageItemTemplateSelector x:Key="ChatMessageItemTemplateSelector">
            <views:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatTextItem}">
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
            <views:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatReasoningItem}">
                    <Border Background="#FFF1F5F9" BorderBrush="#FFCBD5E1" BorderThickness="3,0,0,0" CornerRadius="4" Padding="12,8" Margin="0,2">
                        <StackPanel>
                            <TextBlock Text="思考过程" FontSize="11" Foreground="#FF94A3B8" FontWeight="Medium" />
                            <TextBlock Text="{Binding Text}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
            <views:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatToolItem}">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,2">
                        <StackPanel>
                            <Border Background="#FFF8FAFC" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8">
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,6" Visibility="{Binding HasInputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输入" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" />
                                        <Border Background="#FFF8FAFC" Padding="8" CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding InputText}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding HasOutputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输出" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" />
                                        <Border Background="#FFF8FAFC" Padding="8" CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding OutputText}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
            <views:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatSubAgentItem}">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,2">
                        <StackPanel>
                            <Border Background="#FFF8FAFC" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding MessageItems}" ItemTemplateSelector="{StaticResource ChatMessageItemTemplateSelector}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
            <views:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatImageItem}">
                    <Image Source="{Binding Data, Converter={x:Static converters:BinaryDataToBitmapConverter.Instance}}" MaxWidth="320" Stretch="Uniform" Margin="0,4" />
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
            <views:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatAudioItem}">
                    <Border Background="#FFF1F5F9" CornerRadius="8" Padding="12,8">
                        <TextBlock Text="{Binding DisplayText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </DataTemplate>
            </views:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
        </views:CopilotChatMessageItemTemplateSelector>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Copilot" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          Width="220"
                          ItemsSource="{Binding AvailableModelItems}"
                          SelectedItem="{Binding SelectedModelItem, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ListBox x:Name="ChatListBox"
                     ItemsSource="{Binding CopilotChatManager.ChatMessages}"
                     Background="White"
                     BorderThickness="0"
                     Padding="8"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type agent:CopilotChatMessage}">
                        <Border Margin="4,6"
                                Padding="14"
                                CornerRadius="16"
                                MaxWidth="360"
                                HorizontalAlignment="{Binding Role, Converter={x:Static converters:ChatBubbleAlignmentConverter.Instance}}"
                                Background="{Binding Role, Converter={x:Static converters:ChatBubbleBackgroundConverter.Instance}}">
                            <StackPanel>
                                <TextBlock Text="{Binding Author}"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="{Binding Role, Converter={x:Static converters:ChatBubbleAuthorColorConverter.Instance}}" />
                                <ItemsControl ItemsSource="{Binding MessageItems}"
                                              ItemTemplateSelector="{StaticResource ChatMessageItemTemplateSelector}"
                                              Margin="0,6,0,0" />
                                <TextBlock Text="{Binding UsageSummaryText}"
                                           FontSize="10"
                                           Foreground="#FF94A3B8"
                                           Visibility="{Binding HasUsageDetails, Converter={StaticResource BooleanToVisibility}}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button x:Name="ScrollToBottomButton"
                    Click="ScrollToBottomButton_OnClick"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,16"
                    Width="40"
                    Height="40"
                    Background="{StaticResource PrimaryBlueBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="0"
                    ToolTip="滚动到底部并保持"
                    Cursor="Hand">
                <TextBlock Text="↓" FontSize="20" FontWeight="Bold" Foreground="White" />
            </Button>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <ItemsControl x:Name="AttachedImageFilesItemsControl"
                              ItemsSource="{Binding AttachedImageFiles}" DockPanel.Dock="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type sys:FileInfo}">
                            <Border CornerRadius="8" Width="64" Height="64" Margin="0,0,8,0" Background="#FFF1F5F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding FullName, Converter={x:Static converters:FilePathToImageSourceConverter.Instance}}" Stretch="UniformToFill" Width="64" Height="64" />
                                    <Button Content="✕" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC444444" Foreground="White" FontSize="9" Padding="0" Click="CloseAttachedImageButton_OnClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button x:Name="AttachImageButton"
                        Content="添加图片"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Left"
                        MinWidth="88"
                        Height="36"
                        Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Click="AttachImageButton_OnClick" />
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <Expander FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="高级渲染设置" />
                        <TextBlock Text=" - " />
                        <TextBlock Text="{Binding McpStatusText}" FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             Text="{Binding McpServiceUrl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SingleLineInputTextBoxStyle}"
                             ToolTip="MCP SlideML 渲染服务地址" />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="连接 MCP"
                            Command="{Binding ConnectMcpCommand}"
                            MinWidth="88"
                            Height="34"
                            Margin="8,0,0,0"
                            Padding="12,4"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Text="{Binding McpStatusText}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,6,0,0" />
                </Grid>
            </Expander>
        </Border>

        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatInputTextBox"
                         Grid.Row="0"
                         Grid.ColumnSpan="2"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         MinHeight="42"
                         MaxHeight="120"
                         Style="{StaticResource InputTextBoxStyle}" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="发送"
                        Command="{Binding SendMessageCommand}"
                        MinWidth="88"
                        Height="20"
                        Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="12,2" />
                <CheckBox Grid.Row="1"
                          Grid.Column="0"
                          IsChecked="{Binding AttachPreview}"
                          Margin="0,6,0,0"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}">
                    <TextBlock Text="附带当前预览截图" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </CheckBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
