<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.CopilotPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System.IO;assembly=System.Runtime"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             xmlns:views="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views"
             Background="{StaticResource LightBackgroundBrush}"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760"
             d:DesignWidth="420"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Copilot" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          Width="220"
                          ItemsSource="{Binding AvailableModelItems}"
                          SelectedItem="{Binding SelectedModelItem, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName" />
            </Grid>
        </Border>

        <views:CopilotMessageStream Grid.Row="1"
                                    ItemsSource="{Binding CopilotChatManager.ChatMessages}"
                                    ListBackground="White" />

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <ItemsControl x:Name="AttachedImageFilesItemsControl"
                              ItemsSource="{Binding AttachedImageFiles}" DockPanel.Dock="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type sys:FileInfo}">
                            <Border CornerRadius="8" Width="64" Height="64" Margin="0,0,8,0" Background="#FFF1F5F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding FullName, Converter={x:Static converters:FilePathToImageSourceConverter.Instance}}" Stretch="UniformToFill" Width="64" Height="64" />
                                    <Button Content="✕" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC444444" Foreground="White" FontSize="9" Padding="0" Click="CloseAttachedImageButton_OnClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="添加图片"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Left"
                        MinWidth="88"
                        Height="36"
                        Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Click="AttachImageButton_OnClick" />
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <Expander FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="高级渲染设置" />
                        <TextBlock Text=" - " />
                        <TextBlock Text="{Binding McpStatusText}" FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             Text="{Binding McpServiceUrl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SingleLineInputTextBoxStyle}"
                             ToolTip="MCP SlideML 渲染服务地址" />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="连接 MCP"
                            Command="{Binding ConnectMcpCommand}"
                            MinWidth="88"
                            Height="34"
                            Margin="8,0,0,0"
                            Padding="12,4"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Text="{Binding McpStatusText}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,6,0,0" />
                </Grid>
            </Expander>
        </Border>

        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatInputTextBox"
                         Grid.Row="0"
                         Grid.ColumnSpan="2"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         MinHeight="42"
                         MaxHeight="120"
                         Style="{StaticResource InputTextBoxStyle}" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="发送"
                        Command="{Binding SendMessageCommand}"
                        MinWidth="88"
                        Height="20"
                        Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="12,2" />
                <CheckBox Grid.Row="1"
                          Grid.Column="0"
                          IsChecked="{Binding AttachPreview}"
                          Margin="0,6,0,0"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}">
                    <TextBlock Text="附带当前预览截图" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </CheckBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
