<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.CoursewareAnalysisView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
             xmlns:views="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views"
             d:DataContext="{d:DesignInstance Type=viewModels:CoursewareWorkspaceViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="1000"
             d:DesignWidth="1720"
             Background="{StaticResource AnalysisPageBackgroundBrush}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource AnalysisBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowsCoursewareContext}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="进入页面美化"
                        Command="{Binding EnterWorkspaceCommand}"
                        IsEnabled="{Binding IsAnalysisReady}"
                        Style="{StaticResource AnalysisPrimaryButtonStyle}"
                        AutomationProperties.Name="进入页面美化" />
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" Background="#E7F8F6" CornerRadius="10" Margin="0,0,12,0">
                        <TextBlock Text="▱" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="23" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding ProductTitle}"
                               Foreground="{StaticResource AnalysisNavyBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PageTitle"
                                   Text="{Binding CoursewareTitle, StringFormat=当前课件：{0}}"
                                   Foreground="{StaticResource AnalysisNavyBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Focusable="True"
                                   AutomationProperties.Name="全课件主题分析页面" />
                        <TextBlock Text="{Binding SlideCountText}" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="12" Margin="15,2,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="●" Foreground="{StaticResource AnalysisTealBrush}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AnalysisStatus}" Foreground="{StaticResource AnalysisBodyBrush}" FontSize="12" Margin="6,0,0,0" />
                        <TextBlock Text=" · " Foreground="{StaticResource AnalysisMutedBrush}" FontSize="12" />
                        <TextBlock Text="{Binding AnalysisCaption}" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCoursewareWelcome}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F8FBFC" Offset="0" />
                        <GradientStop Color="#EDF9F7" Offset="0.58" />
                        <GradientStop Color="#EEF4FA" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="780" Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Width="76" Height="76" Background="White" BorderBrush="#B7E4DF" BorderThickness="1" CornerRadius="22" HorizontalAlignment="Center">
                        <TextBlock Text="▱" Foreground="{StaticResource AnalysisTealBrush}" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Row="1" Text="课件智绘" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="38" HorizontalAlignment="Center" Margin="0,22,0,0" />
                    <TextBlock Grid.Row="2"
                               Text="先查看整份课件并形成统一主题，再进入单页美化工作台。"
                               Style="{StaticResource AnalysisBodyTextStyle}"
                               FontSize="16"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,28,0,0">
                        <Button x:Name="OpenCoursewareButton"
                                Content="打开课件文件夹"
                                Click="OpenCoursewareButton_OnClick"
                                Style="{StaticResource AnalysisPrimaryButtonStyle}"
                                MinWidth="210"
                                AutomationProperties.Name="打开课件文件夹" />
                        <TextBlock Text="请选择符合课件 Markdown 导出格式的本地文件夹。"
                                   Foreground="{StaticResource AnalysisMutedBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCoursewareLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                    <StackPanel Margin="24,24,24,22">
                        <StackPanel HorizontalAlignment="Center" Width="620">
                            <Border Width="64" Height="64" Background="#E7F8F6" CornerRadius="32" HorizontalAlignment="Center">
                                <TextBlock Text="…" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="正在读取课件" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="28" HorizontalAlignment="Center" Margin="0,20,0,0" />
                            <TextBlock Text="正在解析课件清单、页面 Markdown、资源索引和页面截图。"
                                       Style="{StaticResource AnalysisBodyTextStyle}"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0" />
                            <Border Height="8" Background="#DCE8EC" CornerRadius="4" Margin="30,24,30,0">
                                <Border Width="250" Background="{StaticResource AnalysisTealBrush}" CornerRadius="4" HorizontalAlignment="Left" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource {x:Type ScrollViewer}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCoursewareLoadFailed}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Border Style="{StaticResource AnalysisCardStyle}" MaxWidth="820" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="26" Margin="24">
                    <StackPanel>
                        <Border Width="54" Height="54" Background="#FFF3D6" CornerRadius="27" HorizontalAlignment="Left">
                            <TextBlock Text="!" Foreground="#B76C00" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="无法读取课件文件夹" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="25" Margin="0,16,0,0" />
                        <TextBlock Text="{Binding LoadErrorMessage}" Style="{StaticResource AnalysisBodyTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <Expander Header="查看技术详情" Margin="0,16,0,0">
                            <TextBox Text="{Binding LoadErrorDetails, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxHeight="220"
                                     Padding="10"
                                     Margin="0,8,0,0" />
                        </Expander>
                        <Button Content="重新选择课件文件夹"
                                Click="OpenCoursewareButton_OnClick"
                                Style="{StaticResource AnalysisPrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"
                                AutomationProperties.Name="重新选择课件文件夹" />
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalyzingTheme}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid Margin="24,16,24,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource AnalysisCardStyle}" Padding="14" Margin="0,0,0,14">
                        <ScrollViewer MaxHeight="147"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <views:CoursewareThumbnailOverview ThumbnailAspectRatio="{Binding ThumbnailAspectRatio, ElementName=Root}" />
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.75*" />
                            <ColumnDefinition Width="1.75*" />
                        </Grid.ColumnDefinitions>
                        <views:CoursewareAnalysisProcessView Margin="0,0,14,0" />
                        <Border Grid.Column="1" Style="{StaticResource AnalysisCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="主题分析"
                                           Style="{StaticResource AnalysisSectionTitleTextStyle}"
                                           Margin="0,0,0,12" />
                                <views:CopilotMessageStream x:Name="AnalysisChatMessageStream"
                                                            Grid.Row="1"
                                                            ItemsSource="{Binding AnalysisChatMessages}"
                                                            ListBackground="Transparent"
                                                            AutomationProperties.Name="主题分析 Copilot 输出" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource {x:Type ScrollViewer}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalysisReady}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid Margin="18,14,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.75*" />
                            <ColumnDefinition Width="1.75*" />
                        </Grid.ColumnDefinitions>
                        <views:CoursewareAnalysisProcessView ShowActions="False" Margin="0,0,14,0" />
                        <views:CoursewareThemeSummaryView Grid.Column="1" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,13,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="进入页面美化" Command="{Binding EnterWorkspaceCommand}" Style="{StaticResource AnalysisPrimaryButtonStyle}" MinWidth="205" AutomationProperties.Name="进入页面美化" />
                            <Button Content="重新分析" Command="{Binding ReanalyzeCommand}" Style="{StaticResource AnalysisSecondaryButtonStyle}" Margin="10,0,0,0" AutomationProperties.Name="重新分析" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource {x:Type ScrollViewer}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalysisFailed}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="24,16,24,24">
                    <Border Style="{StaticResource AnalysisCardStyle}" Padding="12" Margin="0,0,0,16">
                        <views:CoursewareThumbnailOverview ThumbnailAspectRatio="{Binding ThumbnailAspectRatio, ElementName=Root}" />
                    </Border>
                    <Border Style="{StaticResource AnalysisCardStyle}" MaxWidth="820" HorizontalAlignment="Center" Padding="26">
                        <StackPanel>
                            <Border Width="54" Height="54" Background="#FFF3D6" CornerRadius="27" HorizontalAlignment="Left">
                                <TextBlock Text="!" Foreground="#B76C00" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="未能形成有效的统一主题" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="25" Margin="0,16,0,0" />
                            <TextBlock Text="主题结构校验未通过。课件已经载入，但当前没有可进入工作台的有效主题。" Style="{StaticResource AnalysisBodyTextStyle}" Margin="0,8,0,0" />
                            <Expander Header="查看技术详情" Margin="0,16,0,0">
                                <TextBox Text="THEME_VALIDATION_FAILED&#x0a;Theme hierarchy contains inconsistent heading levels."
                                         IsReadOnly="True" TextWrapping="Wrap" Padding="10" Margin="0,8,0,0" />
                            </Expander>
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="重试主题分析" Command="{Binding RetryDemoCommand}" Style="{StaticResource AnalysisPrimaryButtonStyle}" />
                                <Button Content="进入页面美化" Command="{Binding EnterWorkspaceCommand}" Style="{StaticResource AnalysisSecondaryButtonStyle}" IsEnabled="False" Margin="10,0,0,0" AutomationProperties.Name="进入页面美化，不可用" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource {x:Type ScrollViewer}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCanceled}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="24,16,24,24">
                    <Border Style="{StaticResource AnalysisCardStyle}" Padding="12" Margin="0,0,0,16">
                        <views:CoursewareThumbnailOverview ThumbnailAspectRatio="{Binding ThumbnailAspectRatio, RelativeSource={RelativeSource AncestorType={x:Type views:CoursewareAnalysisView}}}" />
                    </Border>
                    <Border Style="{StaticResource AnalysisCardStyle}" MaxWidth="900" HorizontalAlignment="Center" Padding="26">
                        <StackPanel>
                            <TextBlock Text="主题分析已取消" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="25" />
                            <TextBlock Text="{Binding SlideCountText, StringFormat=课件名称和 {0}缩略图仍保留，可以随时重新分析。}" Style="{StaticResource AnalysisBodyTextStyle}" Margin="0,8,0,0" />
                            <ItemsControl ItemsSource="{Binding AnalysisEvents}" Margin="0,18,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="○" Foreground="{StaticResource AnalysisMutedBrush}" Margin="0,0,8,0" />
                                             <TextBlock Text="{Binding Message}" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="12" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="重新分析" Command="{Binding ReanalyzeCommand}" Style="{StaticResource AnalysisPrimaryButtonStyle}" />
                                <Button Content="进入页面美化" Command="{Binding EnterWorkspaceCommand}" Style="{StaticResource AnalysisSecondaryButtonStyle}" IsEnabled="False" Margin="10,0,0,0" AutomationProperties.Name="进入页面美化，不可用" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>