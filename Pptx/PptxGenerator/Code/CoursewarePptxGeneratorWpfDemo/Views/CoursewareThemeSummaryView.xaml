<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.CoursewareThemeSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="390"
             d:DesignWidth="1500"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1.8*" />
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="1.35*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="5"
                Background="{StaticResource AnalysisHeroBackgroundBrush}"
                BorderBrush="#56C7BE"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,17"
                Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource AnalysisPillStyle}">
                    <TextBlock Text="现代" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                    <Border Style="{StaticResource AnalysisPillStyle}">
                        <TextBlock Text="清晰" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                    <Border Style="{StaticResource AnalysisPillStyle}" Margin="0">
                        <TextBlock Text="理性" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                    <Border Style="{StaticResource AnalysisPillStyle}" Margin="8,0,0,0">
                        <TextBlock Text="轻量科技" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{Binding ThemeTitle, StringFormat=主题方案：{0}}" Style="{StaticResource AnalysisTitleTextStyle}" FontSize="26" />
                    <TextBlock Text="{Binding ThemeDescription}"
                               Style="{StaticResource AnalysisBodyTextStyle}"
                               FontSize="14"
                               Margin="0,7,24,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource AnalysisCardStyle}" Margin="0,0,10,0" Padding="14">
            <StackPanel>
                <TextBlock Text="风格关键词" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                <UniformGrid Columns="2" Margin="0,12,0,0">
                    <Border Background="#F3F8FA" CornerRadius="7" Margin="0,0,6,6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="◇" FontSize="22" Foreground="#237E91" HorizontalAlignment="Center" />
                            <TextBlock Text="现代" FontSize="12" Foreground="{StaticResource AnalysisNavyBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="#F3F8FA" CornerRadius="7" Margin="0,0,0,6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="◔" FontSize="22" Foreground="#237E91" HorizontalAlignment="Center" />
                            <TextBlock Text="清晰" FontSize="12" Foreground="{StaticResource AnalysisNavyBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="#F3F8FA" CornerRadius="7" Margin="0,0,6,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="▤" FontSize="22" Foreground="#237E91" HorizontalAlignment="Center" />
                            <TextBlock Text="理性" FontSize="12" Foreground="{StaticResource AnalysisNavyBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="#F3F8FA" CornerRadius="7" Padding="8">
                        <StackPanel>
                            <TextBlock Text="↔" FontSize="22" Foreground="#237E91" HorizontalAlignment="Center" />
                            <TextBlock Text="轻量科技" FontSize="12" Foreground="{StaticResource AnalysisNavyBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource AnalysisCardStyle}" Margin="0,0,10,0" Padding="14">
            <StackPanel>
                <TextBlock Text="配色方案" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                <ItemsControl ItemsSource="{Binding ThemeColors}" Margin="0,12,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,7,0">
                                <Ellipse Width="32" Height="32" HorizontalAlignment="Left">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding HexValue}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding Usage}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AnalysisNavyBrush}" Margin="0,5,0,0" />
                                <TextBlock Text="{Binding HexValue}" FontSize="9" Foreground="{StaticResource AnalysisMutedBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Background="#F4F8FA" CornerRadius="7" Padding="10" Margin="0,12,0,0">
                    <TextBlock Text="蓝色建立稳定的知识结构，橙色仅用于核心结论、例题重点和课堂提示。"
                               Style="{StaticResource AnalysisBodyTextStyle}"
                               FontSize="11" />
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource AnalysisCardStyle}" Margin="0,0,10,0" Padding="14">
            <StackPanel>
                <TextBlock Text="字体层级" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                <TextBlock Text="一级标题" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="20" FontWeight="Bold" Margin="0,12,0,0" />
                <TextBlock Text="微软雅黑，32 pt" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="10" />
                <TextBlock Text="二级标题" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,9,0,0" />
                <TextBlock Text="微软雅黑，24 pt" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="10" />
                <TextBlock Text="正文" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,9,0,0" />
                <TextBlock Text="微软雅黑，18 pt，1.5 倍行距" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="10" />
                <TextBlock Text="辅助文字：仅用于注释、来源或次要说明。" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="10" Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource AnalysisCardStyle}" Margin="0,0,10,0" Padding="14">
            <StackPanel>
                <TextBlock Text="版式原则" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                <ItemsControl ItemsSource="{Binding LayoutPrinciples}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,9">
                                <Border Width="19" Height="19" Background="#E7F8F6" CornerRadius="5" Margin="0,0,7,0">
                                    <TextBlock Text="✓" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding}" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="11" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource AnalysisCardStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="安全区" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                    <Border Height="86" Margin="0,10,8,0" Background="#EEF5F7" BorderBrush="#B9CDD4" BorderThickness="1" CornerRadius="5">
                        <Grid Margin="12,10">
                            <Rectangle Stroke="#43B8C4" StrokeThickness="1" StrokeDashArray="3,2" />
                             <TextBlock Text="0.6 in   0.6 in&#x0a;&#x0a;0.4 in   0.4 in" TextAlignment="Center" VerticalAlignment="Center" Foreground="#52727E" FontSize="9" />
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="页面类型建议" Style="{StaticResource AnalysisCardTitleTextStyle}" />
                    <TextBlock Text="• 封面：突出课题名称和学科识别" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="10" Margin="0,10,0,0" />
                    <TextBlock Text="• 章节：简洁大标题与章节编号" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="10" Margin="0,5,0,0" />
                    <TextBlock Text="• 内容：保证公式、图形和步骤关系" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="10" Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#FFF8E9" CornerRadius="6" Padding="8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding InputHealthText}" Foreground="#8A6320" FontSize="10" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
