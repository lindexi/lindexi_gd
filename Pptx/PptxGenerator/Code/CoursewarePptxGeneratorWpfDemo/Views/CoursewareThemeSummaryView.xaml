<UserControl x:Class="CoursewarePptxGeneratorWpfDemo.Views.CoursewareThemeSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="390"
             d:DesignWidth="1500"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ThemeColumnStyle" TargetType="Border" BasedOn="{StaticResource AnalysisCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinHeight" Value="218" />
        </Style>
        <Style x:Key="ThemeColumnTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource AnalysisCardTitleTextStyle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,11" />
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource AnalysisHeroBackgroundBrush}"
            BorderBrush="#56C7BE"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,13">
        <StackPanel>
            <TextBlock Text="主题方案" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="21" FontWeight="Bold" />
            <TextBlock Margin="0,3,0,12"
                       Text="{Binding ThemeTitle, StringFormat=主题方向：{0} · 年级上册，理性、清晰、现代，呈现数学与理性空间}"
                       Foreground="{StaticResource AnalysisBodyBrush}"
                       FontSize="12" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.3*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ThemeColumnStyle}">
                    <StackPanel>
                        <TextBlock Text="风格关键词" Style="{StaticResource ThemeColumnTitleStyle}" />
                        <UniformGrid Columns="2" Rows="2">
                            <Border Background="#EAF8F7" CornerRadius="7" Margin="0,0,7,7" Padding="8">
                                <StackPanel><TextBlock Text="⌘" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="21" HorizontalAlignment="Center" /><TextBlock Text="清晰几何" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel>
                            </Border>
                            <Border Background="#EAF8F7" CornerRadius="7" Margin="0,0,0,7" Padding="8">
                                <StackPanel><TextBlock Text="♧" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="21" HorizontalAlignment="Center" /><TextBlock Text="配色克制" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel>
                            </Border>
                            <Border Background="#EAF8F7" CornerRadius="7" Margin="0,0,7,0" Padding="8">
                                <StackPanel><TextBlock Text="▣" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="20" HorizontalAlignment="Center" /><TextBlock Text="严谨方案" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel>
                            </Border>
                            <Border Background="#EAF8F7" CornerRadius="7" Padding="8">
                                <StackPanel><TextBlock Text="▱" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="21" HorizontalAlignment="Center" /><TextBlock Text="重视留白" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ThemeColumnStyle}">
                    <StackPanel>
                        <TextBlock Text="配色方案" Style="{StaticResource ThemeColumnTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding ThemeColors}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,7,0">
                                        <Border Height="32" CornerRadius="16" BorderBrush="#D7E2E7" BorderThickness="1">
                                            <Border.Background><SolidColorBrush Color="{Binding HexValue}" /></Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Usage}" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding HexValue}" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="9" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Background="#F4F8FA" CornerRadius="6" Margin="0,13,0,0" Padding="9">
                            <TextBlock Text="蓝色建立教学秩序，橙色只用于结论、重点和课堂提示。" Style="{StaticResource AnalysisBodyTextStyle}" FontSize="10" LineHeight="15" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ThemeColumnStyle}">
                    <StackPanel>
                        <TextBlock Text="字体层级" Style="{StaticResource ThemeColumnTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding TypographyLevels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource AnalysisNavyBrush}" FontSize="11" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{Binding Specification}" Foreground="#2563EB" FontSize="10" FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="微软雅黑 / 等宽无衬线中文字体" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ThemeColumnStyle}">
                    <StackPanel>
                        <TextBlock Text="版式原则" Style="{StaticResource ThemeColumnTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding LayoutPrinciples}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F3F9F9" CornerRadius="6" Padding="7" Margin="0,0,0,7">
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource AnalysisBodyBrush}" FontSize="10" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource ThemeColumnStyle}" Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,11,0">
                            <TextBlock Text="页面安全区" Style="{StaticResource ThemeColumnTitleStyle}" />
                            <Border Height="105" Background="#EDF5F7" BorderBrush="#C8D8DE" BorderThickness="1" CornerRadius="7">
                                <Grid Margin="10">
                                    <Rectangle Fill="White" Stroke="#C2D3D9" StrokeThickness="1" />
                                    <Rectangle Margin="12,9" Stroke="{StaticResource AnalysisTealBrush}" StrokeThickness="1.5" StrokeDashArray="4,3" />
                                    <TextBlock Text="安全区" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="10" FontWeight="SemiBold" />
                                </Grid>
                            </Border>
                            <TextBlock Text="左右 0.6 in · 上下 0.4 in" Foreground="{StaticResource AnalysisMutedBrush}" FontSize="9" Margin="0,7,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="输入风险提示" Style="{StaticResource ThemeColumnTitleStyle}" />
                            <StackPanel Margin="0,1,0,0">
                                <TextBlock Text="▲ 第 3 页背景图像素较低" Foreground="#B76C00" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock Text="▲ 第 8 页公式字号偏小" Foreground="#B76C00" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock Text="▲ 第 15 页单位不统一" Foreground="#B76C00" FontSize="10" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Background="#EAF8F5" CornerRadius="6" Padding="7" Margin="0,12,0,0">
                                <TextBlock Text="演示提示，不影响进入工作台" Foreground="{StaticResource AnalysisTealDarkBrush}" FontSize="9" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
