    <system:String x:Key="PrototypeRenderingLogTitleText">渲染日志（演示）</system:String>
    <system:String x:Key="CapabilityStatusPassedText">已通过</system:String>
    <system:String x:Key="CapabilityStatusNotRequestedText">未请求</system:String>
    <system:String x:Key="CapabilityStatusNotSupportedText">暂不支持</system:String>
    <system:String x:Key="CapabilityStatusFailedText">失败</system:String>
