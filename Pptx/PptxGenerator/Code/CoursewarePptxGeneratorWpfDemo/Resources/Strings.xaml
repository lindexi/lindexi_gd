<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="OpenCoursewarePromptText">打开课件后将先完成全文本分析并生成主题建议。</system:String>
    <system:String x:Key="AnalysisReadyTitleText">课件文本分析完成</system:String>
    <system:String x:Key="AnalysisReadyDescriptionText">主题建议已生成；可执行设计系统、模板编译、视觉分析和真实页面生成尚未完成。</system:String>
    <system:String x:Key="ThemeSuggestionTabText">主题建议</system:String>
