<Window x:Class="CoursewarePptxGeneratorWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:CoursewarePptxGeneratorWpfDemo.ViewModels"
        xmlns:views="clr-namespace:CoursewarePptxGeneratorWpfDemo.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:CoursewareWorkspaceViewModel, IsDesignTimeCreatable=True}"
        Title="课件智绘"
        Height="1000"
        Width="1720"
        MinHeight="820"
        MinWidth="1360"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource AnalysisPageBackgroundBrush}">
        <views:CoursewareAnalysisView x:Name="AnalysisView">
            <views:CoursewareAnalysisView.Style>
                <Style TargetType="views:CoursewareAnalysisView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnalysisPage}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:CoursewareAnalysisView.Style>
        </views:CoursewareAnalysisView>

        <views:SlideWorkspaceView x:Name="WorkspaceView">
            <views:SlideWorkspaceView.Style>
                <Style TargetType="views:SlideWorkspaceView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWorkspacePage}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:SlideWorkspaceView.Style>
        </views:SlideWorkspaceView>
    </Grid>
</Window>
