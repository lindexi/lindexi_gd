<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PptxGenerator"
             xmlns:agent="using:AgentLib.Model"
             xmlns:sys="using:System.IO"
             mc:Ignorable="d"
             x:DataType="vm:MainWindowViewModel"
             d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PptxGenerator.CharUserControl">

    <UserControl.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="ChatTextForegroundBrush" Color="#FF1E293B" />
        <SolidColorBrush x:Key="ChatReasoningBackgroundBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="ChatReasoningBorderBrush" Color="#FFCBD5E1" />
        <SolidColorBrush x:Key="ChatReasoningLabelBrush" Color="#FF94A3B8" />
        <SolidColorBrush x:Key="ChatReasoningTextBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="ChatToolBorderBrush" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="ChatToolHeaderBackgroundBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="ChatToolNameForegroundBrush" Color="#FF334155" />
        <SolidColorBrush x:Key="ChatToolInputForegroundBrush" Color="#FF475569" />
        <SolidColorBrush x:Key="ChatToolOutputForegroundBrush" Color="#FF334155" />
        <SolidColorBrush x:Key="ChatAudioBackgroundBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="ChatAudioTextBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="ChatUsageTextBrush" Color="#FF94A3B8" />

        <!-- 聊天消息子项模板选择器 -->
        <vm:CopilotChatMessageItemTemplateSelector x:Key="ChatMessageItemTemplateSelector">
            <vm:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatTextItem">
                    <TextBlock Text="{Binding Text}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{StaticResource ChatTextForegroundBrush}" />
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
            <vm:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatReasoningItem">
                    <Border Background="{StaticResource ChatReasoningBackgroundBrush}"
                            BorderBrush="{StaticResource ChatReasoningBorderBrush}"
                            BorderThickness="3,0,0,0"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,2">
                        <StackPanel Spacing="4">
                            <TextBlock Text="思考过程"
                                       FontSize="11"
                                       Foreground="{StaticResource ChatReasoningLabelBrush}"
                                       FontWeight="Medium" />
                            <TextBlock Text="{Binding Text}"
                                       FontSize="12"
                                       Foreground="{StaticResource ChatReasoningTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
            <vm:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatToolItem">
                    <Border BorderBrush="{StaticResource ChatToolBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,2">
                        <StackPanel Spacing="0">
                            <!-- 头部：工具名 -->
                            <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#x1F527;"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ChatToolNameForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <!-- 体：输入/输出 -->
                            <Border Padding="12,8">
                                <StackPanel Spacing="6">
                                    <StackPanel IsVisible="{Binding HasInputText}" Spacing="2">
                                        <TextBlock Text="输入"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding InputText}"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ChatToolInputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding HasOutputText}" Spacing="2">
                                        <TextBlock Text="输出"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding OutputText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ChatToolOutputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
            <vm:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatSubAgentItem">
                    <Border BorderBrush="{StaticResource ChatToolBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,2">
                        <StackPanel Spacing="0">
                            <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#x1F527;"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ChatToolNameForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8">
                                <StackPanel Spacing="6">
                                    <StackPanel IsVisible="{Binding HasInputText}" Spacing="2">
                                        <TextBlock Text="输入"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding InputText}"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ChatToolInputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding HasOutputText}" Spacing="2">
                                        <TextBlock Text="输出"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding OutputText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ChatToolOutputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
            <vm:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatImageItem">
                    <Image Source="{Binding Data, Converter={x:Static vm:BinaryDataToBitmapConverter.Instance}}"
                           MaxWidth="320"
                           Stretch="Uniform"
                           Margin="0,4" />
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
            <vm:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
                <DataTemplate x:DataType="agent:CopilotChatAudioItem">
                    <Border Background="{StaticResource ChatAudioBackgroundBrush}"
                            CornerRadius="8"
                            Padding="12,8">
                        <TextBlock Text="{Binding DisplayText}"
                                   FontSize="12"
                                   Foreground="{StaticResource ChatAudioTextBrush}" />
                    </Border>
                </DataTemplate>
            </vm:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
        </vm:CopilotChatMessageItemTemplateSelector>
    </UserControl.Resources>

    <Border CornerRadius="14"
            Background="#FFFFFFFF"
            BorderBrush="#FFE2E8F0"
            BorderThickness="1"
            Padding="0">
        <Grid RowDefinitions="Auto,*,Auto,Auto">
            <!-- 顶部标题栏 -->
            <Border Grid.Row="0"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="SlideML Lab"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#FF0F172A"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="1"
                            Background="#FFF1F5F9"
                            BorderBrush="#FFE2E8F0"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" Foreground="#FF334155" FontSize="12" />
                    </Border>
                </Grid>
            </Border>

            <!-- 聊天气泡列表 -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding ChatMessages}"
                     Background="#FFFFFFFF"
                     BorderThickness="0"
                     Padding="8"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="agent:CopilotChatMessage">
                        <Border Margin="4,6" Padding="14" CornerRadius="16"
                                MaxWidth="640"
                                HorizontalAlignment="{Binding Role, Converter={x:Static vm:ChatBubbleAlignmentConverter.Instance}}"
                                Background="{Binding Role, Converter={x:Static vm:ChatBubbleBackgroundConverter.Instance}}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Author}"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="{Binding Role, Converter={x:Static vm:ChatBubbleAuthorColorConverter.Instance}}" />
                                <!-- 按 MessageItems 逐项渲染 -->
                                <ItemsControl ItemsSource="{Binding MessageItems}"
                                              ItemTemplate="{StaticResource ChatMessageItemTemplateSelector}" />
                                <!-- Token 用量信息（如存在） -->
                                <TextBlock Text="{Binding UsageSummaryText}"
                                           FontSize="10"
                                           Foreground="{StaticResource ChatUsageTextBrush}"
                                           IsVisible="{Binding HasUsageDetails}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 图片附件横排栏 -->
            <Border Grid.Row="2"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <DockPanel>
                    <!-- 横排图片缩略图列表 -->
                    <ItemsControl ItemsSource="{Binding AttachedImageFiles}"
                                  DockPanel.Dock="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sys:FileInfo">
                                <Border CornerRadius="8"
                                        Width="64"
                                        Height="64"
                                        Margin="0,0,8,0"
                                        Background="#FFF1F5F9"
                                        BorderBrush="#FFE2E8F0"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding FullName, Converter={x:Static vm:FilePathToBitmapConverter.Instance}}"
                                               Stretch="UniformToFill"
                                               Width="64"
                                               Height="64" />
                                        <!-- 左上角关闭按钮 -->
                                        <Button Content="✕"
                                                Width="16"
                                                Height="16"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                HorizontalContentAlignment="Center"
                                                Background="#CC444444"
                                                Foreground="White"
                                                FontSize="9"
                                                Padding="0"
                                                CornerRadius="5,5,5,5"
                                                Click="CloseAttachedImageButton_OnClick" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- 右侧附加图片按钮 -->
                    <Button x:Name="AttachImageButton"
                            Content="+ 图片"
                            DockPanel.Dock="Right"
                            MinWidth="72"
                            Height="36"
                            Margin="8,0,0,0"
                            Background="#FF2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"
                            CornerRadius="8"
                            Click="AttachImageButton_OnClick" />
                </DockPanel>
            </Border>

            <!-- 底部输入栏 -->
            <Border Grid.Row="3"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,1,0,0"
                    Padding="12">
                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                    <TextBox Grid.Row="0" Grid.Column="0"
                             Text="{Binding InputText}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="42"
                             MaxHeight="120"
                             Background="White"
                             BorderBrush="#FFCBD5E1"
                             BorderThickness="1"
                             Padding="12,10"
                             Watermark="描述你想做的一页幻灯片…" />
                    <StackPanel Grid.Row="0" Grid.Column="2"
                                Orientation="Horizontal">
                        <Button Content="发送"
                                Command="{Binding SendMessageCommand}"
                                MinWidth="80"
                                Height="42"
                                Margin="10,0,0,0"
                                Background="#FF2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"
                                CornerRadius="10" />
                         <Button Content="评估页面"
                                 Command="{Binding EvaluateCommand}"
                                 MinWidth="80"
                                 Height="42"
                                 Margin="10,0,0,0"
                                 Background="#FF7C3AED"
                                 Foreground="White"
                                 FontWeight="SemiBold"
                                 CornerRadius="10" />
                         <Button Content="评估提示词"
                                 Command="{Binding EvaluatePromptCommand}"
                                 MinWidth="80"
                                 Height="42"
                                 Margin="10,0,0,0"
                                 Background="#FF0891B2"
                                 Foreground="White"
                                 FontWeight="SemiBold"
                                 CornerRadius="10" />
                         <Button x:Name="DebugButton" Content="调试"
                                 MinWidth="80"
                                 Height="42"
                                 Margin="10,0,0,0"
                                 Background="#FF2563EB"
                                 Foreground="White"
                                 FontWeight="SemiBold"
                                 CornerRadius="10" 
                                 Click="DebugButton_OnClick" />
                    </StackPanel>
                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              IsChecked="{Binding AttachPreview}"
                              Margin="0,6,0,0"
                              FontSize="12"
                              Foreground="#FF475569">
                        <TextBlock Text="附带预览截图" FontSize="12" Foreground="#FF475569" />
                    </CheckBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
