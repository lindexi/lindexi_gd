<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PptxGenerator"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1580"
        d:DesignHeight="980"
        x:Class="PptxGenerator.MainWindow"
        Title="PptxGenerator - SlideML Lab"
        Width="1580"
        Height="980"
        MinWidth="1280"
        MinHeight="800"
        Background="#FFF8FAFC">
    <Grid ColumnDefinitions="420,*,Auto" Margin="12">
        <!-- 左侧面板：页面预览 + XML + 警告 -->
        <ScrollViewer Grid.Column="0" Margin="4">
            <StackPanel Spacing="8">
                <!-- 页面预览 -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="页面预览" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A" />
                        <Border Background="#FFF1F5F9"
                                CornerRadius="12"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1"
                                Padding="10"
                                HorizontalAlignment="Stretch">
                            <Viewbox Stretch="Uniform">
                                <Border Width="1280" Height="720" Background="White" CornerRadius="8" ClipToBounds="True" PointerPressed="ImageBorder_OnPointerPressed">
                                    <Image Source="{Binding SlideChatManager.PreviewBitmap}" Stretch="Uniform" />
                                </Border>
                            </Viewbox>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 当前 SlideML XML -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="当前 SlideML" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.CurrentSlideXml}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 MinHeight="140"
                                 MaxHeight="260"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Background="#FFF8FAFC"
                                 BorderBrush="#FFCBD5E1"
                                 BorderThickness="1"
                                 Padding="10" />
                    </StackPanel>
                </Border>

                <!-- 回填后的 XML -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="回填后的 XML" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.RenderedXml}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 MinHeight="140"
                                 MaxHeight="260"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Background="#FFF8FAFC"
                                 BorderBrush="#FFCBD5E1"
                                 BorderThickness="1"
                                 Padding="10" />
                    </StackPanel>
                </Border>

                <!-- 渲染警告 -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="渲染警告" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.WarningText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 MaxHeight="160"
                                 Background="#FFFFFBEB"
                                 BorderBrush="#FFFDE68A"
                                 BorderThickness="1"
                                 Padding="10" />
                    </StackPanel>
                </Border>

                <!-- SlideML 评估结果 -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14"
                        IsVisible="{Binding SlideChatManager.LastEvaluationResult.IsSuccess}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="页面评估" FontSize="16" FontWeight="Bold" Foreground="#FF7C3AED" />
                        <TextBlock Text="{Binding EvaluationSummaryText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FF334155"
                                   IsVisible="{Binding EvaluationSummaryText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                              IsVisible="{Binding SlideChatManager.LastEvaluationResult.IsSuccess}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SlideChatManager.LastEvaluationResult.XmlWellFormedness, StringFormat='XML 规范: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SlideChatManager.LastEvaluationResult.LayoutStructure, StringFormat='布局结构: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SlideChatManager.LastEvaluationResult.VisualBalance, StringFormat='视觉平衡: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlideChatManager.LastEvaluationResult.ConstraintAdherence, StringFormat='约束遵守: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SlideChatManager.LastEvaluationResult.SemanticAlignment, StringFormat='语义对齐: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SlideChatManager.LastEvaluationResult.AestheticQuality, StringFormat='美观度: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SlideChatManager.LastEvaluationResult.Suggestions}"
                                      IsVisible="{Binding SlideChatManager.LastEvaluationResult.IsSuccess}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 提示词评估结果 -->
                <Border CornerRadius="14"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        Padding="14"
                        IsVisible="{Binding SlideChatManager.LastPromptEvaluationResult.IsSuccess}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="提示词评估" FontSize="16" FontWeight="Bold" Foreground="#FF0891B2" />
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FF334155">
                            <TextBlock.Text>
                                <MultiBinding StringFormat='综合评分: {0:F1}/10'>
                                    <Binding Path="SlideChatManager.LastPromptEvaluationResult.OverallScore" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                              IsVisible="{Binding SlideChatManager.LastPromptEvaluationResult.IsSuccess}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SlideChatManager.LastPromptEvaluationResult.Clarity, StringFormat='清晰度: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SlideChatManager.LastPromptEvaluationResult.Completeness, StringFormat='完整性: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SlideChatManager.LastPromptEvaluationResult.ConstraintQuality, StringFormat='约束质量: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlideChatManager.LastPromptEvaluationResult.Actionability, StringFormat='可执行性: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SlideChatManager.LastPromptEvaluationResult.Redundancy, StringFormat='冗余度: {0}/10'}" FontSize="12" Foreground="#FF475569" Margin="0,2" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SlideChatManager.LastPromptEvaluationResult.Suggestions}"
                                      IsVisible="{Binding SlideChatManager.LastPromptEvaluationResult.IsSuccess}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 右侧：聊天区域 -->
        <Grid Grid.Column="1" Margin="4" RowDefinitions="Auto,*">
            <!-- 模型选择栏 -->
            <Border Grid.Row="0"
                    CornerRadius="10"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="1"
                    Padding="10,6"
                    Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="模型:" FontSize="13" FontWeight="SemiBold" Foreground="#FF475569" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding AvailableModelItems}"
                              SelectedItem="{Binding SelectedModelItem}"
                              MinWidth="200"
                              FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>
            <vm:CharUserControl Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
