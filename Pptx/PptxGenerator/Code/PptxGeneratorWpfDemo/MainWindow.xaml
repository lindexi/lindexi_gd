<Window x:Class="PptxGeneratorWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PptxGeneratorWpfDemo"
        xmlns:pg="clr-namespace:PptxGenerator"
        xmlns:converters="clr-namespace:PptxGeneratorWpfDemo.Converters"
        mc:Ignorable="d"
        Title="PptxGenerator - SlideML Lab"
        Width="1580" Height="980"
        MinWidth="1280" MinHeight="800"
        d:DesignWidth="1580"
        d:DesignHeight="980"
        d:DataContext="{d:DesignInstance Type=pg:MainWindowViewModel, IsDesignTimeCreatable=False}"
        Background="#FFF8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:PreviewImageToImageSourceConverter x:Key="PreviewImageToImageSourceConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" Margin="12,12,6,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 页面预览 -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="页面预览" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A" />
                        <Border Background="#FFF1F5F9" CornerRadius="12"
                                BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="10" Margin="0,8,0,0">
                            <Viewbox Stretch="Uniform">
                                <Border Width="1280" Height="720" Background="White" CornerRadius="8"
                                        ClipToBounds="True" MouseLeftButtonDown="ImageBorder_OnMouseLeftButtonDown">
                                    <Image Source="{Binding SlideChatManager.PreviewImage, Converter={StaticResource PreviewImageToImageSourceConverter}}" Stretch="Uniform" />
                                </Border>
                            </Viewbox>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 当前 SlideML XML -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="当前 SlideML" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.CurrentSlideXml, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                 MinHeight="140" MaxHeight="260"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#FFF8FAFC" BorderBrush="#FFCBD5E1" BorderThickness="1"
                                 Padding="10" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- 回填后的 XML -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="回填后的 XML" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.RenderedXml, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                 MinHeight="140" MaxHeight="260"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#FFF8FAFC" BorderBrush="#FFCBD5E1" BorderThickness="1"
                                 Padding="10" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- 渲染警告 -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="渲染警告" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" />
                        <TextBox Text="{Binding SlideChatManager.WarningText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="80" MaxHeight="160"
                                 Background="#FFFFFBEB" BorderBrush="#FFFDE68A" BorderThickness="1"
                                 Padding="10" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- SlideML 评估结果 -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8"
                        Visibility="{Binding SlideChatManager.LastEvaluationResult.IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="页面评估" FontSize="16" FontWeight="Bold" Foreground="#FF7C3AED" />
                        <TextBlock Text="{Binding EvaluationSummaryText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FF334155" Margin="0,4,0,0" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.XmlWellFormedness, StringFormat='XML 规范: {0}/10'}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.LayoutStructure, StringFormat='布局结构: {0}/10'}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.VisualBalance, StringFormat='视觉平衡: {0}/10'}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.ConstraintAdherence, StringFormat='约束遵守: {0}/10'}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.SemanticAlignment, StringFormat='语义对齐: {0}/10'}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastEvaluationResult.AestheticQuality, StringFormat='美观度: {0}/10'}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SlideChatManager.LastEvaluationResult.Suggestions}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 提示词评估结果 -->
                <Border CornerRadius="14" Background="White"
                        BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="14" Margin="0,0,0,8"
                        Visibility="{Binding SlideChatManager.LastPromptEvaluationResult.IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="提示词评估" FontSize="16" FontWeight="Bold" Foreground="#FF0891B2" />
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FF334155" Margin="0,4,0,0"
                                   Text="{Binding SlideChatManager.LastPromptEvaluationResult.OverallScore, StringFormat='综合评分: {0:F1}/10'}" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastPromptEvaluationResult.Clarity, StringFormat='清晰度: {0}/10'}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastPromptEvaluationResult.Completeness, StringFormat='完整性: {0}/10'}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastPromptEvaluationResult.ConstraintQuality, StringFormat='约束质量: {0}/10'}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastPromptEvaluationResult.Actionability, StringFormat='可执行性: {0}/10'}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="#FF475569" Margin="0,2"
                                       Text="{Binding SlideChatManager.LastPromptEvaluationResult.Redundancy, StringFormat='冗余度: {0}/10'}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SlideChatManager.LastPromptEvaluationResult.Suggestions}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 右侧：聊天区域 -->
        <local:CharUserControl Grid.Column="1" Margin="6,12,12,12" />
    </Grid>
</Window>
