<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PptxGenerator.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DotNetCampus.LatestCSharpFeatures" Version="13.0.1" />
    <PackageReference Include="DotNetCampus.ModelContextProtocol" Version="0.1.0-alpha.40" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PptxGenerator.Core\PptxGenerator.Core.csproj" />
    <ProjectReference Include="..\PptxGenerator.Wpf\PptxGenerator.Wpf.csproj" />
  </ItemGroup>

</Project>