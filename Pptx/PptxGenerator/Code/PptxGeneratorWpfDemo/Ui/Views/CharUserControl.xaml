<UserControl x:Class="PptxGeneratorWpfDemo.CharUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PptxGeneratorWpfDemo"
             xmlns:pg="clr-namespace:PptxGenerator"
             xmlns:agent="clr-namespace:AgentLib.Model;assembly=AgentLib"
             xmlns:converters="clr-namespace:PptxGeneratorWpfDemo.Converters"
             xmlns:sys="clr-namespace:System.IO;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="600"
             d:DesignHeight="900">
    <UserControl.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="ChatTextForegroundBrush" Color="#FF1E293B" />
        <SolidColorBrush x:Key="ChatReasoningBackgroundBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="ChatReasoningBorderBrush" Color="#FFCBD5E1" />
        <SolidColorBrush x:Key="ChatReasoningLabelBrush" Color="#FF94A3B8" />
        <SolidColorBrush x:Key="ChatReasoningTextBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="ChatToolBorderBrush" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="ChatToolHeaderBackgroundBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="ChatToolNameForegroundBrush" Color="#FF334155" />
        <SolidColorBrush x:Key="ChatToolInputForegroundBrush" Color="#FF475569" />
        <SolidColorBrush x:Key="ChatToolOutputForegroundBrush" Color="#FF334155" />
        <SolidColorBrush x:Key="ChatAudioBackgroundBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="ChatAudioTextBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="ChatUsageTextBrush" Color="#FF94A3B8" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <!-- 聊天消息子项模板选择器 -->
        <pg:CopilotChatMessageItemTemplateSelector x:Key="ChatMessageItemTemplateSelector">
            <pg:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatTextItem}">
                    <TextBlock Text="{Binding Text}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{StaticResource ChatTextForegroundBrush}" />
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.TextItemTemplate>
            <pg:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatReasoningItem}">
                    <Border Background="{StaticResource ChatReasoningBackgroundBrush}"
                            BorderBrush="{StaticResource ChatReasoningBorderBrush}"
                            BorderThickness="3,0,0,0"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,2">
                        <StackPanel>
                            <TextBlock Text="思考过程"
                                       FontSize="11"
                                       Foreground="{StaticResource ChatReasoningLabelBrush}"
                                       FontWeight="Medium" />
                            <TextBlock Text="{Binding Text}"
                                       FontSize="12"
                                       Foreground="{StaticResource ChatReasoningTextBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.ReasoningItemTemplate>
            <pg:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatToolItem}">
                    <Border BorderBrush="{StaticResource ChatToolBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,2">
                        <StackPanel>
                            <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ChatToolNameForegroundBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8">
                                <StackPanel>
                                    <StackPanel x:Name="InputSection" Margin="0,0,0,6"
                                                Visibility="{Binding HasInputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输入"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding InputText}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ChatToolInputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel x:Name="OutputSection"
                                                Visibility="{Binding HasOutputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输出"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding OutputText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ChatToolOutputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.ToolItemTemplate>
            <pg:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatSubAgentItem}">
                    <Border BorderBrush="{StaticResource ChatToolBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,2">
                        <StackPanel>
                            <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ToolName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ChatToolNameForegroundBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8">
                                <StackPanel>
                                    <StackPanel x:Name="SubInputSection" Margin="0,0,0,6"
                                                Visibility="{Binding HasInputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输入"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding InputText}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ChatToolInputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel x:Name="SubOutputSection"
                                                Visibility="{Binding HasOutputText, Converter={StaticResource BooleanToVisibility}}">
                                        <TextBlock Text="输出"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ChatReasoningLabelBrush}"
                                                   FontWeight="Medium" />
                                        <Border Background="{StaticResource ChatToolHeaderBackgroundBrush}"
                                                Padding="8"
                                                CornerRadius="4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding OutputText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ChatToolOutputForegroundBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding MessageItems}"
                                                  ItemTemplateSelector="{StaticResource ChatMessageItemTemplateSelector}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.SubAgentItemTemplate>
            <pg:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatImageItem}">
                    <Image Source="{Binding Data, Converter={x:Static converters:BinaryDataToBitmapConverter.Instance}}"
                           MaxWidth="320"
                           Stretch="Uniform"
                           Margin="0,4" />
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.ImageItemTemplate>
            <pg:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
                <DataTemplate DataType="{x:Type agent:CopilotChatAudioItem}">
                    <Border Background="{StaticResource ChatAudioBackgroundBrush}"
                            CornerRadius="8"
                            Padding="12,8">
                        <TextBlock Text="{Binding DisplayText}"
                                   FontSize="12"
                                   Foreground="{StaticResource ChatAudioTextBrush}" />
                    </Border>
                </DataTemplate>
            </pg:CopilotChatMessageItemTemplateSelector.AudioItemTemplate>
        </pg:CopilotChatMessageItemTemplateSelector>

    </UserControl.Resources>

    <Border CornerRadius="14"
            Background="White"
            BorderBrush="#FFE2E8F0"
            BorderThickness="1"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SlideML Lab"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#FF0F172A"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="1"
                            Background="#FFF1F5F9"
                            BorderBrush="#FFE2E8F0"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" Foreground="#FF334155" FontSize="12" />
                    </Border>
                </Grid>
            </Border>

            <!-- 聊天气泡列表 -->
            <Grid Grid.Row="1">
                <ListBox x:Name="ChatListBox"
                         ItemsSource="{Binding CopilotChatManager.ChatMessages}"
                         Background="White"
                         BorderThickness="0"
                         Padding="8"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type agent:CopilotChatMessage}">
                            <Border Margin="4,6" Padding="14" CornerRadius="16"
                                    MaxWidth="640"
                                    HorizontalAlignment="{Binding Role, Converter={x:Static converters:ChatBubbleAlignmentConverter.Instance}}"
                                    Background="{Binding Role, Converter={x:Static converters:ChatBubbleBackgroundConverter.Instance}}">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding}">
                                        <MenuItem Header="重新开始"
                                                  Click="RestartFromMessageMenuItem_OnClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <TextBlock Text="{Binding Author}"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Foreground="{Binding Role, Converter={x:Static converters:ChatBubbleAuthorColorConverter.Instance}}" />
                                    <ItemsControl ItemsSource="{Binding MessageItems}"
                                                  ItemTemplateSelector="{StaticResource ChatMessageItemTemplateSelector}"
                                                  Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding UsageSummaryText}"
                                               FontSize="10"
                                               Foreground="{StaticResource ChatUsageTextBrush}"
                                               Visibility="{Binding HasUsageDetails, Converter={StaticResource BooleanToVisibility}}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 滚动到底部按钮（用户不在底部时显示） -->
                <Button x:Name="ScrollToBottomButton"
                        Click="ScrollToBottomButton_OnClick"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,16"
                        Width="40" Height="40"
                        Background="#FF2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="0"
                        ToolTip="滚动到底部并保持"
                        Cursor="Hand">
                    <TextBlock Text="↓"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White" />
                </Button>
            </Grid>

            <!-- 图片附件横排栏 -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <DockPanel>
                    <ItemsControl ItemsSource="{Binding AttachedImageFiles}"
                                  DockPanel.Dock="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type sys:FileInfo}">
                                <Border CornerRadius="8"
                                        Width="64" Height="64"
                                        Margin="0,0,8,0"
                                        Background="#FFF1F5F9"
                                        BorderBrush="#FFE2E8F0"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding FullName, Converter={x:Static converters:FilePathToImageSourceConverter.Instance}}"
                                               Stretch="UniformToFill"
                                               Width="64" Height="64" />
                                        <Button Content="✕"
                                                Width="16" Height="16"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Background="#CC444444"
                                                Foreground="White"
                                                FontSize="9"
                                                Padding="0"
                                                Click="CloseAttachedImageButton_OnClick" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button x:Name="AttachImageButton"
                            Content="+ 图片"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Left"
                            MinWidth="72" Height="36"
                            Margin="8,0,0,0"
                            Background="#FF2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="AttachImageButton_OnClick" />
                </DockPanel>
            </Border>

            <!-- 底部输入栏 -->
            <Border Grid.Row="3"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,1,0,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Row="0" Grid.Column="0"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="42"
                             MaxHeight="120"
                             Background="White"
                             BorderBrush="#FFCBD5E1"
                             BorderThickness="1"
                             Padding="12,10" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                        <Button Content="发送"
                                Command="{Binding SendMessageCommand}"
                                MinWidth="80" Height="42"
                                Background="#FF2563EB"
                                Foreground="White"
                                FontWeight="SemiBold" />
                        <Button Content="评估页面"
                                Command="{Binding EvaluateCommand}"
                                MinWidth="80" Height="42"
                                Margin="10,0,0,0"
                                Background="#FF7C3AED"
                                Foreground="White"
                                FontWeight="SemiBold" />
                        <Button Content="评估提示词"
                                Command="{Binding EvaluatePromptCommand}"
                                MinWidth="80" Height="42"
                                Margin="10,0,0,0"
                                Background="#FF0891B2"
                                Foreground="White"
                                FontWeight="SemiBold" />
                        <Button Content="总结"
                                MinWidth="80" Height="42"
                                Margin="10,0,0,0"
                                Background="#FFF59E0B"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Click="ReduceButton_OnClick" />
                    </StackPanel>
                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              IsChecked="{Binding AttachPreview}"
                              Margin="0,6,0,0"
                              FontSize="12"
                              Foreground="#FF475569">
                        <TextBlock Text="附带预览截图" FontSize="12" Foreground="#FF475569" />
                    </CheckBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
