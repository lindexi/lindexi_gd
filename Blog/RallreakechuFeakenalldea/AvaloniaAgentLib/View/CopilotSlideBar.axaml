<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:view="clr-namespace:AvaloniaAgentLib.View"
             xmlns:model="clr-namespace:AgentLib.Model;assembly=AgentLib"
             xmlns:viewModel="clr-namespace:AvaloniaAgentLib.ViewModel"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="AvaloniaAgentLib.View.CopilotSlideBar"
             x:DataType="viewModel:CopilotViewModel">
    <UserControl.DataContext>
        <viewModel:CopilotViewModel />
    </UserControl.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="avares://SimpleWrite/Styles/MainStyles.axaml"></StyleInclude>
    </Design.DesignStyle>
    <UserControl.Resources>
        <DataTemplate x:Key="SessionTemplate" x:DataType="model:CopilotChatSession">
            <TextBlock Text="{Binding DisplayText}" />
        </DataTemplate>

        <DataTemplate x:Key="UserMessageTemplate" x:DataType="model:CopilotChatMessage">
            <StackPanel HorizontalAlignment="Right" Margin="0,0,0,10">
                <TextBlock Classes="SecondaryText" Text="{Binding Author}" Margin="4,0,4,2" HorizontalAlignment="Right" />
                <Border Background="#FF2F6FED" CornerRadius="8" Padding="10,8">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制正文" Click="CopyContentMenuItem_OnClick" CommandParameter="{Binding}" />
                            <MenuItem Header="复制整条" Click="CopyFullMessageMenuItem_OnClick"
                                      CommandParameter="{Binding}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#FFFFFFFF" />
                </Border>
                <TextBlock Classes="SecondaryText" Text="{Binding TimeText}" HorizontalAlignment="Right"
                           Margin="4,2,4,0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" x:DataType="model:CopilotChatMessage">
            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Classes="SecondaryText" Text="{Binding Author}" Margin="4,0,4,2" />
                <Border Background="#FF2A2A2A" CornerRadius="8" Padding="10,8">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制正文" Click="CopyContentMenuItem_OnClick" CommandParameter="{Binding}" />
                            <MenuItem Header="复制正文和思考内容" Click="CopyContentAndReasonMenuItem_OnClick"
                                      CommandParameter="{Binding}" />
                            <MenuItem Header="复制整条" Click="CopyFullMessageMenuItem_OnClick"
                                      CommandParameter="{Binding}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <ItemsControl ItemsSource="{Binding MessageItems}"
                                  ItemTemplate="{StaticResource CopilotChatMessageItemTemplateSelector}" />
                </Border>
                <Border Classes="UsageSummaryBorder"
                        IsVisible="{Binding HasUsageDetails}"
                        Margin="4,2,0,0"
                        Opacity="0.7"
                        HorizontalAlignment="Right">
                    <TextBlock Classes="UsageSummaryText"
                               Text="{Binding UsageSummaryText}"
                               TextWrapping="Wrap" />
                </Border>
                <TextBlock Classes="SecondaryText" Text="{Binding TimeText}" HorizontalAlignment="Right"
                           Margin="4,2,4,0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AssistantTextItemTemplate" x:DataType="model:CopilotChatTextItem">
            <StackPanel Margin="0,0,0,8"
                        IsVisible="{Binding HasText}">
                <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#FFF0F0F0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AssistantReasoningItemTemplate" x:DataType="model:CopilotChatReasoningItem">
            <StackPanel Margin="0,0,0,8"
                        IsVisible="{Binding HasText}"
                        Spacing="4">
                <TextBlock Classes="SecondaryText" Text="思考" />
                <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#FFD0D0D0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AssistantToolItemTemplate" x:DataType="model:CopilotChatToolItem">
            <Expander Margin="0,0,0,8" Background="#FF242424">
                <Expander.Styles>
                    <Style Selector="ToggleButton#ExpanderHeader">
                        <Setter Property="Background" Value="#FF141414"></Setter>
                        <Setter Property="Foreground" Value="White"></Setter>
                        <Style Selector="^ /template/ Border#ToggleButtonBackground:pointerover">
                            <Setter Property="Background" Value="#FF242424"></Setter>
                        </Style>
                        <Style Selector="^:unchecked /template/ Path">
                            <Setter Property="Stroke" Value="#FFE9FFFE">
                                <!-- 比如分开 unchecked 和 checked 分别设置，否则将设置无效。原因是被 unchecked 等给限制了 -->
                            </Setter>
                        </Style>
                        <Style Selector="^:checked /template/ Path">
                            <Setter Property="Stroke" Value="#FFE9FFFE" />
                        </Style>
                    </Style>
                </Expander.Styles>
                <Expander.Header>
                    <TextBlock Text="{Binding DisplayName}" Foreground="#FFE5E5E5" />
                </Expander.Header>
                <StackPanel Margin="0,8,0,0" Spacing="8">
                    <StackPanel IsVisible="{Binding HasInputText}" Spacing="4">
                        <TextBlock Classes="SecondaryText" Text="输入参数" />
                        <SelectableTextBlock Text="{Binding InputText}" TextWrapping="Wrap" Foreground="#FFDFDFDF" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding HasOutputText}" Spacing="4">
                        <TextBlock Classes="SecondaryText" Text="工具输出" />
                        <SelectableTextBlock Text="{Binding OutputText}" TextWrapping="Wrap" Foreground="#FFF0F0F0" />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="AssistantSubAgentItemTemplate" x:DataType="model:CopilotChatSubAgentItem">
            <Expander Margin="0,0,0,8" Background="#FF1F2430" IsExpanded="True">
                <Expander.Styles>
                    <Style Selector="ToggleButton#ExpanderHeader">
                        <Setter Property="Background" Value="#FF162033"></Setter>
                        <Setter Property="Foreground" Value="White"></Setter>
                        <Style Selector="^ /template/ Border#ToggleButtonBackground:pointerover">
                            <Setter Property="Background" Value="#FF243149"></Setter>
                        </Style>
                        <Style Selector="^:unchecked /template/ Path">
                            <Setter Property="Stroke" Value="#FFD9E7FF" />
                        </Style>
                        <Style Selector="^:checked /template/ Path">
                            <Setter Property="Stroke" Value="#FFD9E7FF" />
                        </Style>
                    </Style>
                </Expander.Styles>
                <Expander.Header>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding DisplayName}" Foreground="#FFF2F6FF" />
                        <TextBlock Classes="SecondaryText" Text="子代理进度" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0" Spacing="8">
                    <StackPanel IsVisible="{Binding HasInputText}" Spacing="4">
                        <TextBlock Classes="SecondaryText" Text="任务输入" />
                        <SelectableTextBlock Text="{Binding InputText}" TextWrapping="Wrap" Foreground="#FFE1E9F8" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding MessageItems}"
                                  IsVisible="{Binding HasMessageItems}"
                                  ItemTemplate="{StaticResource CopilotChatMessageItemTemplateSelector}" />
                    <StackPanel IsVisible="{Binding HasOutputText}" Spacing="4">
                        <TextBlock Classes="SecondaryText" Text="返回上级代理的输出" />
                        <SelectableTextBlock Text="{Binding OutputText}" TextWrapping="Wrap" Foreground="#FFF7FBFF" />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </DataTemplate>

        <view:CopilotChatMessageTemplateSelector x:Key="CopilotChatMessageTemplateSelector"
                                                 UserTemplate="{StaticResource UserMessageTemplate}"
                                                 AssistantTemplate="{StaticResource AssistantMessageTemplate}"
                                                 SystemTemplate="{StaticResource AssistantMessageTemplate}" />

        <view:CopilotChatMessageItemTemplateSelector x:Key="CopilotChatMessageItemTemplateSelector"
                                                     TextItemTemplate="{StaticResource AssistantTextItemTemplate}"
                                                     ReasoningItemTemplate="{StaticResource AssistantReasoningItemTemplate}"
                                                     ToolItemTemplate="{StaticResource AssistantToolItemTemplate}"
                                                     SubAgentItemTemplate="{StaticResource AssistantSubAgentItemTemplate}" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Border.CardBorder">
            <Setter Property="Background" Value="#FF1B1B1B" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="10,0,10,0" />
        </Style>
        <Style Selector="TextBlock.HeaderTitle">
            <Setter Property="Foreground" Value="#FFF2F2F2" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.SecondaryText">
            <Setter Property="Foreground" Value="#FF9F9F9F" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Border.UsageSummaryBorder">
            <Setter Property="Background" Value="#FF2B2B2B" />
            <Setter Property="Padding" Value="5,2,5,0" />
        </Style>
        <Style Selector="TextBlock.UsageSummaryText">
            <Setter Property="Foreground" Value="#FFE8F1FF" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style Selector="TextBox.MessageInputTextBox">
            <Setter Property="Background" Value="#FF222222" />
            <Setter Property="Foreground" Value="#FF5F5F5F" />
            <Setter Property="BorderBrush" Value="#FF454545" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="MaxHeight" Value="140" />
        </Style>
    </UserControl.Styles>

    <Border Background="#FF141414" BorderThickness="1,0,0,0" BorderBrush="#FF3B3B3B">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border Classes="CardBorder" Margin="10,0,10,6"
                    Padding="12,2,12,0">
                <StackPanel>
                    <ComboBox MinWidth="130"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding CanEditInput}"
                              ItemsSource="{Binding ChatSessions}"
                              SelectedItem="{Binding SelectedSession}"
                              ItemTemplate="{StaticResource SessionTemplate}"
                              SelectionChanged="SessionSelector_OnSelectionChanged" />
                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Classes="InteractiveButton SecondaryButton"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding CanEditInput}"
                                Click="NewSessionButton_OnClick"
                                Content="新建会话" />
                        <Button x:Name="SettingButton"
                                Classes="InteractiveButton SecondaryButton"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                Content="设置"
                                Click="SettingButton_OnClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Classes="CardBorder" Margin="10,0,10,6" Padding="8">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ChatMessages}"
                                  ItemTemplate="{StaticResource CopilotChatMessageTemplateSelector}" />
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Classes="CardBorder" Margin="10,0,10,10" Padding="10">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBox x:Name="InputTextBox"
                             Grid.ColumnSpan="2"
                             Classes="MessageInputTextBox"
                             IsEnabled="{Binding CanEditInput}"
                             Watermark="输入消息，Enter 发送，Shift+Enter 换行"
                             KeyDown="InputTextBox_OnKeyDown" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Classes="InteractiveButton PrimaryButton"
                            x:Name="SendButton"
                            Content="{Binding SendButtonText}"
                            Click="SendButton_OnClick" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>