<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SimpleWrite.ViewModels"
             xmlns:models="clr-namespace:SimpleWrite.Models"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="25"
             x:Name="RootTabBar"
             x:Class="SimpleWrite.Views.Components.TabBar"
             x:DataType="viewModels:SimpleWriteMainViewModel"
             >
    <Design.DataContext>
        <viewModels:SimpleWriteMainViewModel/>
    </Design.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="avares://SimpleWrite/Styles/MainStyles.axaml"></StyleInclude>
    </Design.DesignStyle>
    <Border x:Name="TabBarBorder" Background="{StaticResource Brush.Background.TabBar}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border.Subtle}">
      <ListBox x:Name="EditorTabListBox" SelectionMode="Single" Background="Transparent"
               PointerWheelChanged="EditorTabListBox_OnPointerWheelChanged"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Disabled"
               ItemsSource="{Binding Path=EditorViewModel.EditorModelList}"
               SelectedItem="{Binding Path=EditorViewModel.CurrentEditorModel}">
          <ListBox.Styles>
              <Style Selector="ListBox#EditorTabListBox /template/ ScrollViewer#PART_ScrollViewer /template/ ScrollBar:horizontal">
                  <Setter Property="Height" Value="4" />
                  <Setter Property="MinHeight" Value="4" />
                  <Setter Property="Margin" Value="6,0,6,1" />
                  <Setter Property="Opacity" Value="0.7" />
              </Style>
              <Style Selector="ListBox#EditorTabListBox /template/ ScrollViewer#PART_ScrollViewer /template/ ScrollBar:horizontal:pointerover">
                  <Setter Property="Opacity" Value="1" />
              </Style>
              <Style Selector="ListBox#EditorTabListBox /template/ ScrollViewer#PART_ScrollViewer /template/ ScrollBar:horizontal /template/ Thumb">
                  <Setter Property="Height" Value="4" />
                  <Setter Property="MinHeight" Value="4" />
                  <Setter Property="Background" Value="{StaticResource Brush.Thumb.Background}" />
              </Style>
              <Style Selector="ListBox#EditorTabListBox /template/ ScrollViewer#PART_ScrollViewer /template/ ScrollBar:horizontal /template/ Thumb:pointerover">
                  <Setter Property="Background" Value="{StaticResource Brush.Thumb.Background}" />
              </Style>
              <Style Selector="Border.Tab-Main-Style">
                  <Setter Property="Background" Value="{StaticResource Brush.Background.TabBar}" />
              </Style>
              <Style Selector="ListBoxItem:selected Border.Tab-Main-Style">
                  <Setter Property="Background" Value="{StaticResource Brush.Background.TabSelected}" />
                  <!-- <Setter Property="CornerRadius" Value="5 5 0 0"></Setter> -->
              </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                  <StackPanel x:Name="EditorTabStackPanel" Orientation="Horizontal"></StackPanel>
              </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemContainerTheme>
              <ControlTheme TargetType="ListBoxItem">
                  <Setter Property="Margin" Value="0"></Setter>
              </ControlTheme>
          </ListBox.ItemContainerTheme>
          <ListBox.ItemTemplate>
              <DataTemplate DataType="models:EditorModel">
                  <Border x:Name="TabItemBorder" Classes="Tab-Main-Style" 
                          Margin="0,3,2,0" 
                          Padding="5,2,5,0"
                          BorderThickness="0 0 1 0"
                           BorderBrush="{StaticResource Brush.Border.Subtle}">
                      <!-- 以下设置无效 -->
                      <!-- <Border.Styles> -->
                      <!--     <Style Selector="Border:selected"> -->
                      <!--         <Setter Property="Background" Value="Red" /> -->
                      <!--     </Style> -->
                      <!-- </Border.Styles> -->

                      <!-- 每个标签的部分 -->
                      <Border.ContextMenu>
                          <ContextMenu x:Name="TabItemContextMenu">
                              <MenuItem x:Name="OpenInFileExplorerMenuItem" Header="在文件资源管理器中打开" Click="OpenInFileExplorerMenuItem_OnClick" />
                          </ContextMenu>
                      </Border.ContextMenu>
                      <StackPanel Orientation="Horizontal">
                           <TextBlock x:Name="TabTitleTextBlock" MinWidth="30" Text="{Binding Title}" Foreground="{StaticResource Brush.Foreground.Primary}"
                                     ToolTip.Tip="{Binding FileInfo.FullName}">
                              <!-- 添加 MinWidth 是为了防止标题太短而误点到关闭按钮上 -->
                          </TextBlock>
                           <Button x:Name="CloseTabButton" Margin="5 0 0 0" Background="Transparent" Padding="0"
                                   Foreground="{StaticResource Brush.Foreground.Secondary}"
                                  VerticalAlignment="Center" Click="CloseTabButton_OnClick">
                              <Path Stroke="{Binding #CloseTabButton.Foreground}" StrokeThickness="2" Data="M0,0 L6,6z M6,0 L0,6"></Path>
                          </Button>
                      </StackPanel>
                  </Border>
                </DataTemplate>
          </ListBox.ItemTemplate>
      </ListBox>
    </Border>
</UserControl>
