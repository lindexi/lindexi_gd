<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SimpleWrite.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SimpleWrite.Views.Components.SimpleWriteSideBar"
             x:DataType="viewModels:FolderExplorerViewModel"
             MinWidth="0"
             ClipToBounds="False"
             Background="{StaticResource Brush.Background.Panel}">
    <Design.DataContext>
        <viewModels:FolderExplorerViewModel />
    </Design.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="avares://SimpleWrite/Styles/MainStyles.axaml"></StyleInclude>
    </Design.DesignStyle>
    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.18" />
        </Transitions>
    </UserControl.Transitions>

    <Grid>
        <Border x:Name="SidebarContentHost"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource Brush.Border.Subtle}">
            <Grid RowDefinitions="*,Auto,Auto"
                  Margin="8">
                <Button x:Name="OpenFolderButton"
                        Grid.Row="1"
                        Classes="InteractiveButton SecondaryButton"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsEmptyStateVisible}"
                        Click="OpenFolderButton_OnClick">打开文件夹</Button>

                <StackPanel Grid.Row="2"
                            Margin="0,8,0,8"
                            Spacing="6">
                    <TextBlock x:Name="CurrentFolderCaptionTextBlock"
                               Text="当前文件夹"
                               Foreground="{StaticResource Brush.Foreground.Muted}"
                               IsVisible="{Binding HasOpenedFolder}" />
                    <TextBlock x:Name="CurrentFolderPathTextBlock"
                               Text="{Binding CurrentFolderPath}"
                               Foreground="{StaticResource Brush.Foreground.Secondary}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasOpenedFolder}" />
                    <Button x:Name="ClearFolderButton"
                            Classes="InteractiveButton SecondaryButton"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding HasOpenedFolder}"
                            Click="ClearFolderButton_OnClick">关闭文件夹</Button>
                    <TextBlock x:Name="EmptyFolderTextBlock"
                               Text="打开文件夹后，可在这里展开目录并直接打开文件。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.Foreground.Muted}"
                               IsVisible="{Binding IsEmptyStateVisible}" />
                </StackPanel>

                <TreeView x:Name="FolderTreeView"
                          Grid.Row="0"
                          Classes="LightTreeView"
                          Foreground="{StaticResource Brush.Foreground.Secondary}"
                          ItemsSource="{Binding RootItems}"
                          IsVisible="{Binding HasOpenedFolder}"
                          DoubleTapped="FolderTreeView_OnDoubleTapped">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="viewModels:FolderTreeItemViewModel"
                                          ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <TextBlock Text="{Binding IconText}"
                                           Foreground="{StaticResource Brush.Foreground.Secondary}" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource Brush.Foreground.Secondary}" />
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <Button x:Name="ToggleSidebarButton"
                Classes="InteractiveButton SecondaryButton"
                Width="32"
                Height="84"
                Background="{StaticResource Brush.Background.Toggle}"
                Padding="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Click="ToggleSidebarButton_OnClick">
            <Button.Styles>
                <Style Selector="Button">
                    <Setter Property="Opacity" Value="0.5"></Setter>
                </Style>
                <Style Selector="Button:pointerover">
                    <Style.Animations>
                        <Animation Duration="0:0:0.2" FillMode="Backward">
                            <KeyFrame Cue="50%">
                                <Setter Property="Opacity" Value="0.5" />
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="1.0" />
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                    <Setter Property="Opacity" Value="1"></Setter>
                </Style>
            </Button.Styles>
            <StackPanel Spacing="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="ToggleChevronTextBlock"
                           Text="❮"
                           FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
