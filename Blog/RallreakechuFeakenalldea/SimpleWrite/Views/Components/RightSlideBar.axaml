<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:view="clr-namespace:AvaloniaAgentLib.View;assembly=AvaloniaAgentLib"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SimpleWrite.Views.Components.RightSlideBar"
             MinWidth="40"
             ClipToBounds="True">
    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.18" />
        </Transitions>
    </UserControl.Transitions>

    <Grid ColumnDefinitions="6,Auto,*">
        <Border x:Name="ResizeHandleBorder"
                Grid.Column="0"
                Background="Transparent"
                Cursor="SizeWestEast"
                PointerPressed="ResizeHandleBorder_OnPointerPressed"
                PointerMoved="ResizeHandleBorder_OnPointerMoved"
                PointerReleased="ResizeHandleBorder_OnPointerReleased"
                PointerCaptureLost="ResizeHandleBorder_OnPointerCaptureLost" />

        <Border Grid.Column="1"
                Background="#FF141414"
                BorderThickness="1,0,0,0"
                BorderBrush="#FF3B3B3B">
            <Button x:Name="ToggleSidebarButton"
                    Classes="InteractiveButton SecondaryButton"
                    Width="32"
                    Height="84"
                    Margin="4,12,4,12"
                    Padding="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Click="ToggleSidebarButton_OnClick">
                <StackPanel Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="ToggleChevronTextBlock"
                               Text="❯"
                               FontSize="14"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="AI"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </Border>

        <Border x:Name="SidebarContentHost"
                Grid.Column="2">
            <view:CopilotSlideBar x:Name="CopilotSlideBar" />
        </Border>
    </Grid>
</UserControl>
