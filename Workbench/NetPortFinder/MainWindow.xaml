<Window x:Class="NetPortFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="端口占用检测器"
        Width="1500"
        Height="900"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F6FB">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF7F9FC" Offset="0" />
            <GradientStop Color="#FFEAF0FF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="BorderBrush" Value="#FFD3DBEA" />
            <Setter Property="Background" Value="#FFFDFEFF" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="22,12" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FF4C6FFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3D5EF0" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF9AA8E8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="28,28,28,18" Padding="30" CornerRadius="28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF4C6FFF" Offset="0" />
                    <GradientStop Color="#FF7B61FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="端口占用检测器" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="#EAF2FF"
                               TextWrapping="Wrap"
                               Text="输入端口后，程序将依次尝试监听 127.0.0.1 / 0.0.0.0 的 TCP 与 UDP，并在下方输出检测过程与可能占用端口的进程。" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="76"
                        Height="76"
                        Margin="24,0,0,0"
                        Background="#26FFFFFF"
                        CornerRadius="18"
                        VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="36"
                               Text="⚡" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="28,0,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF24324A"
                               Text="输入待检测端口" />
                    <TextBox x:Name="PortTextBox"
                             Margin="0,10,0,6"
                             Height="44"
                             MaxLength="5"
                             Text="5000"
                             VerticalContentAlignment="Center" />
                    <TextBlock FontSize="12"
                               Foreground="#FF6B768A"
                               Text="支持 1 ~ 65535，例如 80、443、5000。" />
                </StackPanel>

                <Button x:Name="DetectButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="DetectButton_OnClick"
                        Content="开始检测" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="28,18,28,28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FF24324A"
                               Text="检测日志" />
                    <TextBlock DockPanel.Dock="Right"
                               Foreground="#FF6B768A"
                               VerticalAlignment="Center"
                               Text="实时输出检测过程与结果" />
                </DockPanel>

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="0,18,0,0"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="#FF0F172A"
                         Foreground="#FFE2E8F0"
                         BorderThickness="0"
                         Padding="16" />
            </Grid>
        </Border>
    </Grid>
</Window>
